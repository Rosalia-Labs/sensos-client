#!/usr/bin/env python3
# SPDX-License-Identifier: MIT

from __future__ import annotations

import argparse
import importlib.util
import json
import os
import platform
import socket
import subprocess
import sys
from pathlib import Path

SCRIPT_FILE = Path(__file__).resolve()
SCRIPT_DIR = SCRIPT_FILE.parent
OVERLAY_ROOT = Path(os.environ.get("SENSOS_CLIENT_ROOT", "/sensos"))
UTILS_FILE = OVERLAY_ROOT / "libexec" / "utils.py"

if not UTILS_FILE.is_file():
    raise RuntimeError(f"Missing utils.py at {UTILS_FILE}")

UTILS_SPEC = importlib.util.spec_from_file_location("sensos_overlay_utils", UTILS_FILE)
UTILS_MODULE = importlib.util.module_from_spec(UTILS_SPEC)
assert UTILS_SPEC.loader is not None
UTILS_SPEC.loader.exec_module(UTILS_MODULE)

for name in dir(UTILS_MODULE):
    if not name.startswith("_"):
        globals()[name] = getattr(UTILS_MODULE, name)

REQUESTS = None


def http_requests():
    global REQUESTS
    if REQUESTS is None:
        REQUESTS = require_requests()
    return REQUESTS


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog=SCRIPT_FILE.name,
        description="Upload the local hardware profile to the server.",
    )
    parser.add_argument(
        "--transport",
        choices=["auto", "steady-state", "setup"],
        default="auto",
        help="API transport to use: WireGuard steady-state, setup-time API, or auto fallback order (default: auto).",
    )
    return parser.parse_args()


def read_first_line(path: str) -> str | None:
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            return handle.readline().strip() or None
    except OSError:
        return None


def run_json(cmd: list[str], default):
    try:
        output = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
        return json.loads(output)
    except Exception:
        return default


def run_lines(cmd: list[str]) -> list[str]:
    try:
        output = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
    except Exception:
        return []
    return [line.strip() for line in output.splitlines() if line.strip()]


def collect_model() -> str:
    return (
        read_first_line("/proc/device-tree/model")
        or read_first_line("/sys/devices/virtual/dmi/id/product_name")
        or platform.machine()
    )


def collect_cpu() -> dict:
    model_name = None
    hardware = None
    serial = None
    try:
        with open("/proc/cpuinfo", "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                if ":" not in line:
                    continue
                key, value = [part.strip() for part in line.split(":", 1)]
                if key == "model name" and model_name is None:
                    model_name = value
                elif key == "Hardware" and hardware is None:
                    hardware = value
                elif key == "Serial" and serial is None:
                    serial = value
    except OSError:
        pass
    return {
        "architecture": platform.machine(),
        "model_name": model_name,
        "hardware": hardware,
        "serial": serial,
        "logical_cpus": os.cpu_count(),
    }


def collect_firmware() -> dict:
    return {
        "bios_vendor": read_first_line("/sys/devices/virtual/dmi/id/bios_vendor"),
        "bios_version": read_first_line("/sys/devices/virtual/dmi/id/bios_version"),
        "board_name": read_first_line("/sys/devices/virtual/dmi/id/board_name"),
        "board_vendor": read_first_line("/sys/devices/virtual/dmi/id/board_vendor"),
    }


def collect_memory() -> dict:
    mem_total_kb = None
    mem_available_kb = None
    try:
        with open("/proc/meminfo", "r", encoding="utf-8") as handle:
            for line in handle:
                if line.startswith("MemTotal:"):
                    mem_total_kb = int(line.split()[1])
                elif line.startswith("MemAvailable:"):
                    mem_available_kb = int(line.split()[1])
    except OSError:
        pass
    return {
        "mem_total_mb": mem_total_kb // 1024 if mem_total_kb is not None else None,
        "mem_available_mb": mem_available_kb // 1024 if mem_available_kb is not None else None,
    }


def collect_disks() -> dict[str, dict]:
    data = run_json(["lsblk", "-J", "-b", "-o", "NAME,PATH,SIZE,MODEL,TYPE,ROTA,TRAN"], {"blockdevices": []})
    disks = {}
    for device in data.get("blockdevices", []):
        if device.get("type") != "disk":
            continue
        disk_name = device.get("name") or device.get("path") or f"disk-{len(disks) + 1}"
        disks[disk_name] = {
            "name": device.get("name"),
            "path": device.get("path"),
            "size_bytes": device.get("size"),
            "model": device.get("model"),
            "transport": device.get("tran"),
            "rotational": device.get("rota"),
        }
    return disks


def collect_usb_devices() -> str:
    return "\n".join(run_lines(["lsusb"]))


def collect_network_interfaces() -> dict[str, dict]:
    data = run_json(["ip", "-json", "addr", "show"], [])
    interfaces = {}
    for entry in data:
        addresses = entry.get("addr_info", [])
        iface_name = entry.get("ifname") or f"iface-{len(interfaces) + 1}"
        interfaces[iface_name] = {
            "name": entry.get("ifname"),
            "mac_address": entry.get("address"),
            "operstate": entry.get("operstate"),
            "mtu": entry.get("mtu"),
            "ipv4": [addr.get("local") for addr in addresses if addr.get("family") == "inet"],
            "ipv6": [addr.get("local") for addr in addresses if addr.get("family") == "inet6"],
        }
    return interfaces


def build_hardware_profile_payload(hostname: str | None = None) -> dict:
    return {
        "hostname": hostname or socket.gethostname(),
        "model": collect_model(),
        "kernel_version": platform.release(),
        "cpu": collect_cpu(),
        "firmware": collect_firmware(),
        "memory": collect_memory(),
        "disks": collect_disks(),
        "usb_devices": collect_usb_devices(),
        "network_interfaces": collect_network_interfaces(),
    }


def upload_hardware_profile(server_ip: str, port: str, peer_uuid: str, api_password: str, payload: dict):
    url = f"http://{server_ip}:{port}/api/v1/client/peer/hardware-profile"
    headers = {
        **build_basic_auth_header(api_password, username=peer_uuid),
        "Content-Type": "application/json",
    }
    return http_requests().put(url, headers=headers, json=payload, timeout=15)


def resolve_upload_targets(config: dict, transport: str) -> list[tuple[str, str]]:
    targets: list[tuple[str, str]] = []

    steady_host = config.get("SERVER_WG_IP")
    steady_port = config.get("SERVER_PORT") or DEFAULT_PORT
    setup_host = config.get("SETUP_API_HOST")
    setup_port = config.get("SETUP_API_PORT") or DEFAULT_PORT

    if transport in ("auto", "steady-state") and steady_host:
        targets.append((steady_host, str(steady_port)))
    if transport in ("auto", "setup") and setup_host:
        candidate = (setup_host, str(setup_port))
        if candidate not in targets:
            targets.append(candidate)

    if transport == "steady-state":
        require_nonempty(steady_host, "SERVER_WG_IP")
        require_nonempty(steady_port, "SERVER_PORT")
    elif transport == "setup":
        require_nonempty(setup_host, "SETUP_API_HOST")
        require_nonempty(setup_port, "SETUP_API_PORT")
    elif not targets:
        require_nonempty(steady_host or setup_host, "SERVER_WG_IP or SETUP_API_HOST")

    return targets


def main() -> int:
    args = parse_args()
    config = read_network_conf()
    peer_uuid = require_peer_uuid(config)

    api_password = read_api_password()
    if not api_password:
        raise SystemExit("Error: client API password required to upload hardware profile.")

    payload = build_hardware_profile_payload()
    targets = resolve_upload_targets(config, args.transport)
    request_errors = []

    for server_ip, port in targets:
        try:
            response = upload_hardware_profile(server_ip, port, peer_uuid, api_password, payload)
        except Exception as exc:
            request_errors.append(f"{server_ip}:{port}: {exc}")
            continue

        if response.status_code != 200:
            raise SystemExit(
                f"Error: upload-hardware-profile failed via {server_ip}:{port}: "
                f"{response.status_code} {response.text}"
            )

        print(f"✅ Hardware profile uploaded for peer {peer_uuid} via {server_ip}:{port}.")
        return 0

    detail = "; ".join(request_errors) if request_errors else "no usable API target configured"
    raise SystemExit(f"Error: upload-hardware-profile could not reach any API target: {detail}")


if __name__ == "__main__":
    raise SystemExit(main())
