import argparse
import importlib.util
import os
import sys

SCRIPT_FILE = os.path.realpath(__file__)
SCRIPT_DIR = os.path.dirname(SCRIPT_FILE)
OVERLAY_ROOT = os.environ.get("SENSOS_CLIENT_ROOT", "/sensos")
CLIENT_ROOT = os.environ.get("SENSOS_CLIENT_ROOT", OVERLAY_ROOT)
UTILS_FILE = os.path.join(OVERLAY_ROOT, "libexec", "utils.py")

if not os.path.isfile(UTILS_FILE):
    raise RuntimeError(f"Missing utils.py at {UTILS_FILE}")

UTILS_SPEC = importlib.util.spec_from_file_location("sensos_overlay_utils", UTILS_FILE)
UTILS_MODULE = importlib.util.module_from_spec(UTILS_SPEC)
assert UTILS_SPEC.loader is not None
UTILS_SPEC.loader.exec_module(UTILS_MODULE)

for name in dir(UTILS_MODULE):
    if not name.startswith("_"):
        globals()[name] = getattr(UTILS_MODULE, name)

LOCATION_CONF = os.path.join(CLIENT_ROOT, "etc", "location.conf")
REQUESTS = None


def http_requests():
    global REQUESTS
    if REQUESTS is None:
        REQUESTS = require_requests()
    return REQUESTS


def send_location(server_host, port, peer_uuid, api_password, latitude, longitude):
    payload = {
        "latitude": latitude,
        "longitude": longitude,
    }
    url = f"http://{server_host}:{port}/api/v1/client/peer/location"
    headers = {
        **build_basic_auth_header(api_password, username=peer_uuid),
        "Content-Type": "application/json",
    }

    try:
        response = http_requests().put(url, headers=headers, json=payload, timeout=5)
    except Exception as exc:
        print(f"❌ Request failed: {exc}", file=sys.stderr)
        return

    if response.status_code == 200:
        print(f"✅ Location updated to ({latitude}, {longitude}) for {peer_uuid}.")
        return

    print(f"❌ Server responded with {response.status_code}: {response.text}", file=sys.stderr)


def write_local_location_conf(latitude, longitude):
    create_dir(os.path.dirname(LOCATION_CONF), owner="sensos-admin", group="sensos-data", mode=0o2775)
    content = f"LATITUDE={latitude}\nLONGITUDE={longitude}\n"
    write_file(LOCATION_CONF, content, mode=0o664, user="sensos-admin", group="sensos-data")
    print(f"✅ Location written to {LOCATION_CONF}")


def is_interactive():
    return sys.stdin.isatty()


def prompt_for_float(prompt_text):
    while True:
        raw = input(f"{prompt_text}: ").strip()
        try:
            return float(raw)
        except ValueError:
            print("❌ Please enter a valid number.", file=sys.stderr)


def fill_missing_location_args(args):
    missing = []
    if args.latitude is None:
        missing.append("--latitude")
    if args.longitude is None:
        missing.append("--longitude")

    if not missing:
        return args

    if not is_interactive():
        joined = ", ".join(missing)
        print(
            f"❌ Missing required values: {joined}. Run interactively to be prompted, "
            "or pass both flags.",
            file=sys.stderr,
        )
        raise SystemExit(1)

    if args.latitude is None:
        args.latitude = prompt_for_float("Latitude")
    if args.longitude is None:
        args.longitude = prompt_for_float("Longitude")
    return args


def main():
    ensure_sensos_admin()
    arg_defs = [
        (["--latitude"], {"type": float, "help": "Latitude"}),
        (["--longitude"], {"type": float, "help": "Longitude"}),
        (["--setup-server"], {"help": "Override setup-time API server hostname or IP", "dest": "config_server"}),
        (["--setup-port"], {"help": "Override setup-time API port", "dest": "port"}),
    ]
    args = parse_args_with_defaults(arg_defs, ["global", "config_location"])
    args = fill_missing_location_args(args)

    write_local_location_conf(args.latitude, args.longitude)

    conf = read_network_conf()
    server_host = args.config_server or conf.get("SERVER_WG_IP")
    port = args.port or conf.get("SERVER_PORT") or DEFAULT_PORT
    peer_uuid = conf.get("PEER_UUID")

    if not server_host:
        print("ℹ️ No config server configured; saved location locally only.")
        return 0

    if not peer_uuid:
        print(f"❌ Missing PEER_UUID in {NETWORK_CONF}.", file=sys.stderr)
        return 1

    api_password = read_api_password()
    if not api_password:
        print("❌ Client API password required to sync location to the server.", file=sys.stderr)
        return 1

    send_location(server_host, port, peer_uuid, api_password, args.latitude, args.longitude)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
