#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_FILE}")" && pwd)"
resolve_overlay_root() {
    printf '%s\n' "${SENSOS_CLIENT_ROOT:-/sensos}"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
PARSE_SWITCHES_LIB="${OVERLAY_ROOT}/libexec/parse-switches.sh"
DATA_STORAGE_OPS_LIB="${OVERLAY_ROOT}/libexec/data-storage-ops.sh"
SENSOS_ADMIN_HELPER_LIB="${OVERLAY_ROOT}/libexec/ensure-sensos-admin.sh"

[[ -f "${PARSE_SWITCHES_LIB}" ]] || {
    echo "ERROR: missing parse-switches library at ${PARSE_SWITCHES_LIB}" >&2
    exit 1
}
source "${PARSE_SWITCHES_LIB}"
[[ -f "${DATA_STORAGE_OPS_LIB}" ]] || {
    echo "ERROR: missing data storage ops library at ${DATA_STORAGE_OPS_LIB}" >&2
    exit 1
}
source "${DATA_STORAGE_OPS_LIB}"
[[ -f "${SENSOS_ADMIN_HELPER_LIB}" ]] || {
    echo "ERROR: missing sensos-admin helper at ${SENSOS_ADMIN_HELPER_LIB}" >&2
    exit 1
}
source "${SENSOS_ADMIN_HELPER_LIB}"

ensure_sensos_admin_user "${SCRIPT_FILE}" "$@"

STATE_DIR="/sensos/log"
STATE_FILE="${DATA_ARCHIVE_MODE_STATE_FILE}"

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Enter or exit archive mode for /sensos/data.

Options:
  --status      Show archive mode and data-service status
  --enter       Stop writers, checkpoint SQLite, and sync storage
  --exit        Return to normal operation
  --clear-data  When exiting, clear /sensos/data in place first
EOF
}

write_state_marker() {
    local active_units_serialized="${1:-}"
    sudo install -d -m 2775 "${STATE_DIR}"
    sudo sh -c "cat >'${STATE_FILE}'" <<EOF
ARCHIVE_MODE_ACTIVE=1
ARCHIVE_MODE_ENTERED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
ARCHIVE_MODE_ACTIVE_UNITS=${active_units_serialized}
EOF
}

clear_state_marker() {
    sudo rm -f "${STATE_FILE}"
}

archive_mode_is_active() {
    sudo test -f "${STATE_FILE}"
}

read_state_marker() {
    sudo cat "${STATE_FILE}"
}

main() {
    local enter exit_mode clear_data status
    local archive_state mount_state writers_state
    local -a active_units=()
    local active_units_serialized=""

    enter="false"
    exit_mode="false"
    clear_data="false"
    status="false"

    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
        usage
        return 0
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --enter)
                enter="true"
                ;;
            --status)
                status="true"
                ;;
            --exit)
                exit_mode="true"
                ;;
            --clear-data)
                clear_data="true"
                ;;
            *)
                echo "ERROR: unknown option: $1" >&2
                usage
                exit 1
                ;;
        esac
        shift
    done

    if [[ "${status}" == "true" ]]; then
        if [[ "${enter}" == "true" || "${exit_mode}" == "true" || "${clear_data}" == "true" ]]; then
            echo "ERROR: --status cannot be combined with other options." >&2
            exit 1
        fi

        if archive_mode_is_active; then
            archive_state="active"
        else
            archive_state="inactive"
        fi

        if mountpoint -q "${DATA_MOUNT}"; then
            mount_state="mounted"
        elif data_ops_uses_root_filesystem; then
            mount_state="rootfs"
        else
            mount_state="unmounted"
        fi

        if data_ops_any_data_writer_active; then
            writers_state="active"
        else
            writers_state="inactive"
        fi

        echo "archive_mode=${archive_state}"
        echo "data_mount=${mount_state}"
        echo "data_writers=${writers_state}"
        echo "state_file=${STATE_FILE}"
        return 0
    fi

    if [[ "${enter}" == "${exit_mode}" ]]; then
        echo "ERROR: specify exactly one of --enter or --exit." >&2
        exit 1
    fi

    data_ops_require_cmd mountpoint
    data_ops_require_cmd findmnt
    data_ops_require_cmd sqlite3
    data_ops_require_cmd sync
    data_ops_require_cmd systemctl

    [[ -d "${DATA_MOUNT}" ]] || {
        echo "ERROR: data mount path not found: ${DATA_MOUNT}" >&2
        exit 1
    }

    if [[ "${enter}" == "true" ]]; then
        if archive_mode_is_active; then
            echo "Archive mode is already active (${STATE_FILE})." >&2
            echo "Use archive-mode --exit to return to normal operation first." >&2
            exit 1
        fi
        echo "Entering archive mode for ${DATA_MOUNT}..."
        while IFS= read -r unit_name; do
            [[ -n "${unit_name}" ]] || continue
            active_units+=("${unit_name}")
        done < <(data_ops_list_active_units)

        if [[ ${#active_units[@]} -gt 0 ]]; then
            printf -v active_units_serialized '%q ' "${active_units[@]}"
            active_units_serialized="${active_units_serialized% }"
        fi

        data_ops_stop_data_units
        data_ops_checkpoint_sqlite_dbs
        data_ops_sync_storage
        write_state_marker "${active_units_serialized}"
        echo "Archive mode active."
        echo "Data under ${DATA_MOUNT} is now quiesced and ready for copy or media swap."
        return 0
    fi

    if ! archive_mode_is_active; then
        echo "ERROR: archive mode is not active." >&2
        echo "Run archive-mode --enter before using archive-mode --exit." >&2
        exit 1
    fi

    echo "Exiting archive mode for ${DATA_MOUNT}..."
    if ! data_ops_storage_is_available; then
        if ! data_ops_try_mount_data; then
            echo "ERROR: ${DATA_MOUNT} is not mounted and could not be remounted automatically." >&2
            echo "Run config-storage or mount ${DATA_MOUNT} manually, then retry archive-mode --exit." >&2
            exit 1
        fi
    fi

    if [[ "${clear_data}" == "true" ]]; then
        data_ops_reset_data_root
    elif data_ops_has_meaningful_data_content; then
        echo "WARNING: ${DATA_MOUNT} still contains data."
        echo "If you intend to start a fresh epoch, either:"
        echo "  archive-mode --exit --clear-data"
        echo "or rerun config-storage and choose to clear ${DATA_MOUNT}."
    fi

    active_units=()
    eval "$(read_state_marker)"

    data_ops_sync_storage
    if [[ -n "${ARCHIVE_MODE_ACTIVE_UNITS:-}" ]]; then
        # shellcheck disable=SC2206
        active_units=( ${ARCHIVE_MODE_ACTIVE_UNITS} )
        data_ops_start_selected_units "${active_units[@]}"
    fi
    clear_state_marker
    echo "Archive mode exited."
}

main "$@"
