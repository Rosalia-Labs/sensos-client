import os
import sqlite3
import shutil
import subprocess
import sys
import time
from pathlib import Path


CLIENT_ROOT = Path(os.environ.get("SENSOS_CLIENT_ROOT", "/sensos"))
DATA_ROOT = CLIENT_ROOT / "data" / "audio_recordings"
QUEUED_ROOT = DATA_ROOT / "queued"
COMPRESSED_ROOT = DATA_ROOT / "compressed"
PROCESSED_ROOT = DATA_ROOT / "processed"
BIRDNET_DB = CLIENT_ROOT / "data" / "birdnet" / "birdnet.db"
ARECORD_CONF = CLIENT_ROOT / "etc" / "arecord.conf"
OUTPUT_LINE_LIMIT = 9


def read_kv(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key.strip()] = value.strip()
    return values


def run_command(args: list[str]) -> str:
    result = subprocess.run(args, text=True, capture_output=True, check=False)
    return result.stdout.strip() if result.returncode == 0 else ""


def systemd_state(unit: str) -> tuple[str, str]:
    enabled = run_command(["systemctl", "is-enabled", unit]) or "not-found"
    active = run_command(["systemctl", "is-active", unit]) or "inactive"
    return enabled, active


def summarize_tree(root: Path, suffix: str | None = None) -> dict[str, object]:
    count = 0
    newest_mtime = None
    oldest_mtime = None

    if not root.exists():
        return {"count": 0, "newest_age": None, "oldest_age": None}

    for dirpath, _, filenames in os.walk(root):
        for filename in filenames:
            if suffix and not filename.endswith(suffix):
                continue
            path = Path(dirpath) / filename
            try:
                stat = path.stat()
            except FileNotFoundError:
                continue
            count += 1
            mtime = stat.st_mtime
            if newest_mtime is None or mtime > newest_mtime:
                newest_mtime = mtime
            if oldest_mtime is None or mtime < oldest_mtime:
                oldest_mtime = mtime

    now = time.time()
    newest_age = None if newest_mtime is None else max(0, int(now - newest_mtime))
    oldest_age = None if oldest_mtime is None else max(0, int(now - oldest_mtime))
    return {"count": count, "newest_age": newest_age, "oldest_age": oldest_age}


def format_age(seconds: object) -> str:
    if seconds is None:
        return "-"
    value = int(seconds)
    if value < 60:
        return f"{value}s"
    if value < 3600:
        return f"{value // 60}m"
    if value < 86400:
        return f"{value // 3600}h"
    return f"{value // 86400}d"


def arecord_live_hint(queued_newest_age: object) -> str:
    config = read_kv(ARECORD_CONF)
    try:
        max_time = int(config.get("MAX_TIME", "300"))
    except ValueError:
        max_time = 300
    live_window = max(120, max_time * 2)
    if queued_newest_age is None:
        return "no"
    return "yes" if int(queued_newest_age) <= live_window else "no"


def birdnet_db_summary() -> dict[str, object]:
    summary = {"files": "-", "det": "-", "up": "-"}
    if not BIRDNET_DB.exists():
        return summary
    try:
        conn = sqlite3.connect(BIRDNET_DB)
        with conn:
            summary["files"] = conn.execute(
                "select count(*) from processed_files"
            ).fetchone()[0]
            summary["det"] = conn.execute(
                "select count(*) from detections"
            ).fetchone()[0]
            try:
                summary["up"] = conn.execute(
                    "select count(*) from processed_files where coalesce(server_copy,0)=0"
                ).fetchone()[0]
            except sqlite3.DatabaseError:
                summary["up"] = "-"
    except sqlite3.DatabaseError:
        summary["files"] = "db-err"
        summary["det"] = "db-err"
        summary["up"] = "db-err"
    return summary


def build_lines() -> list[str]:
    queued = summarize_tree(QUEUED_ROOT, ".wav")
    compressed = summarize_tree(COMPRESSED_ROOT, ".flac")
    processed = summarize_tree(PROCESSED_ROOT, ".flac")
    birdnet_db = birdnet_db_summary()

    arecord_en, arecord_ac = systemd_state("sensos-record-audio.service")
    compress_en, compress_ac = systemd_state("sensos-compress-audio.service")
    birdnet_en, birdnet_ac = systemd_state("sensos-birdnet.service")

    def service_summary(active: str, enabled: str) -> str:
        return f"{active}, {enabled}"

    lines = [
        f"root       {DATA_ROOT}",
        (
            f"services   arecord={service_summary(arecord_ac, arecord_en)} | "
            f"compress={service_summary(compress_ac, compress_en)} | "
            f"birdnet={service_summary(birdnet_ac, birdnet_en)}"
        ),
        (
            f"queued     files={queued['count']} newest={format_age(queued['newest_age'])} "
            f"oldest={format_age(queued['oldest_age'])} "
            f"recording_live={arecord_live_hint(queued['newest_age'])}"
        ),
        (
            f"compressed files={compressed['count']} newest={format_age(compressed['newest_age'])} "
            f"oldest={format_age(compressed['oldest_age'])}"
        ),
        (
            f"processed  files={processed['count']} newest={format_age(processed['newest_age'])} "
            f"oldest={format_age(processed['oldest_age'])}"
        ),
        (
            f"birdnet db files={birdnet_db['files']} detections={birdnet_db['det']} "
            f"pending_upload={birdnet_db['up']}"
        ),
    ]
    return lines[:OUTPUT_LINE_LIMIT]


def main() -> int:
    if shutil.which("systemctl") is None:
        print("ERROR: systemctl not found", file=sys.stderr)
        return 1
    for line in build_lines():
        print(line)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
