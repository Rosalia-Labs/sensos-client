#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_FILE}")" && pwd)"

resolve_overlay_root() {
    printf '%s\n' "${SENSOS_CLIENT_ROOT:-/sensos}"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
DATA_STORAGE_OPS_LIB="${OVERLAY_ROOT}/libexec/data-storage-ops.sh"

[[ -f "${DATA_STORAGE_OPS_LIB}" ]] || {
    echo "ERROR: missing data storage ops library at ${DATA_STORAGE_OPS_LIB}" >&2
    exit 1
}
source "${DATA_STORAGE_OPS_LIB}"

TOP_N=10
TARGET_PATH="${DATA_MOUNT}"
AUDIO_ROOT="${DATA_MOUNT}/audio_recordings"
QUEUED_ROOT="${AUDIO_ROOT}/queued"
COMPRESSED_ROOT="${AUDIO_ROOT}/compressed"
PROCESSED_ROOT="${AUDIO_ROOT}/processed"
BIRDNET_ROOT="${DATA_MOUNT}/birdnet"
BIRDNET_DB="${BIRDNET_ROOT}/birdnet.db"

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Summarize a data directory without printing a full recursive listing.

Options:
  --path PATH   Directory to summarize (default: ${DATA_MOUNT})
  --top N       Number of rows for bounded sections (default: ${TOP_N})
  -h, --help    Show this help text

Notes:
  - This command is intended for Linux targets with GNU find/stat support.
  - Output is bounded, but the scan still walks the directory tree.
EOF
}

require_dir() {
    [[ -d "$1" ]] || {
        echo "ERROR: directory not found: $1" >&2
        exit 1
    }
}

print_header() {
    printf '%s\n' "$1"
}

print_simple_metric() {
    printf '%-18s %s\n' "$1" "$2"
}

path_within_target() {
    local candidate="$1"
    case "${candidate}" in
        "${TARGET_PATH}"|${TARGET_PATH}/*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

collect_counts() {
    local target_path="$1"
    local files dirs symlinks others

    files="$(find "${target_path}" -type f 2>/dev/null | wc -l | tr -d ' ')"
    dirs="$(find "${target_path}" -type d 2>/dev/null | wc -l | tr -d ' ')"
    symlinks="$(find "${target_path}" -type l 2>/dev/null | wc -l | tr -d ' ')"
    others="$(find "${target_path}" \( ! -type f -a ! -type d -a ! -type l \) 2>/dev/null | wc -l | tr -d ' ')"

    print_simple_metric "files" "${files}"
    print_simple_metric "directories" "${dirs}"
    print_simple_metric "symlinks" "${symlinks}"
    print_simple_metric "other entries" "${others}"
}

print_filesystem_summary() {
    local target_path="$1"
    local total_size

    print_header "Directory Summary"
    print_simple_metric "path" "${target_path}"
    if mountpoint -q "${target_path}"; then
        print_simple_metric "mountpoint" "yes"
    else
        print_simple_metric "mountpoint" "no"
    fi
    total_size="$(du -sh "${target_path}" 2>/dev/null | awk '{print $1}')"
    print_simple_metric "total size" "${total_size}"
    collect_counts "${target_path}"

    printf '\n'
    print_header "Filesystem Usage"
    df -h "${target_path}" | sed 's/^/  /'
}

print_top_level_sizes() {
    local target_path="$1"
    local top_n="$2"

    printf '\n'
    print_header "Top-Level Usage"
    if find "${target_path}" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
        du -sh "${target_path}"/* 2>/dev/null | sort -hr | head -n "${top_n}" | sed 's/^/  /'
    else
        printf '  %s\n' "(empty)"
    fi
}

print_largest_files() {
    local target_path="$1"
    local top_n="$2"

    printf '\n'
    print_header "Largest Files"
    if find "${target_path}" -type f -print -quit 2>/dev/null | grep -q .; then
        find "${target_path}" -type f -printf '%s\t%TY-%Tm-%Td %TH:%TM\t%p\n' 2>/dev/null \
            | sort -nr \
            | head -n "${top_n}" \
            | awk -F '\t' '{printf "  %.1f MiB\t%s\t%s\n", $1/1048576, $2, $3}'
    else
        printf '  %s\n' "(no files)"
    fi
}

print_recent_files() {
    local target_path="$1"
    local top_n="$2"

    printf '\n'
    print_header "Most Recent Files"
    if find "${target_path}" -type f -print -quit 2>/dev/null | grep -q .; then
        find "${target_path}" -type f -printf '%T@\t%TY-%Tm-%Td %TH:%TM\t%p\n' 2>/dev/null \
            | sort -nr \
            | head -n "${top_n}" \
            | cut -f2- \
            | sed 's/^/  /'
    else
        printf '  %s\n' "(no files)"
    fi
}

stage_file_count() {
    local root="$1"
    if [[ ! -d "${root}" ]]; then
        printf '0'
        return
    fi
    find "${root}" -type f 2>/dev/null | wc -l | tr -d ' '
}

stage_total_size() {
    local root="$1"
    if [[ ! -d "${root}" ]]; then
        printf '0'
        return
    fi
    du -sh "${root}" 2>/dev/null | awk '{print $1}'
}

stage_mtime_summary() {
    local root="$1"
    local order="$2"

    if [[ ! -d "${root}" ]]; then
        printf '%s\n' "-"
        return
    fi

    if ! find "${root}" -type f -print -quit 2>/dev/null | grep -q .; then
        printf '%s\n' "-"
        return
    fi

    find "${root}" -type f -printf '%T@\t%TY-%Tm-%Td %TH:%TM\t%p\n' 2>/dev/null \
        | sort "${order}" \
        | head -n 1 \
        | cut -f2-
}

print_stage_summary() {
    local label="$1"
    local root="$2"

    printf '\n'
    print_header "${label}"
    print_simple_metric "path" "${root}"
    print_simple_metric "files" "$(stage_file_count "${root}")"
    print_simple_metric "size" "$(stage_total_size "${root}")"
    print_simple_metric "oldest file" "$(stage_mtime_summary "${root}" -n)"
    print_simple_metric "newest file" "$(stage_mtime_summary "${root}" -nr)"
}

print_birdnet_db_summary() {
    local pending_uploads processed_ok processed_error db_size

    [[ -f "${BIRDNET_DB}" ]] || return 0
    command -v sqlite3 >/dev/null 2>&1 || return 0

    pending_uploads="$(sqlite3 "${BIRDNET_DB}" "select count(*) from processed_files where coalesce(server_copy,0)=0 and status='done';" 2>/dev/null || printf 'unknown')"
    processed_ok="$(sqlite3 "${BIRDNET_DB}" "select count(*) from processed_files where status='done';" 2>/dev/null || printf 'unknown')"
    processed_error="$(sqlite3 "${BIRDNET_DB}" "select count(*) from processed_files where status<>'done';" 2>/dev/null || printf 'unknown')"
    db_size="$(du -sh "${BIRDNET_DB}" 2>/dev/null | awk '{print $1}')"

    printf '\n'
    print_header "BirdNET DB"
    print_simple_metric "db path" "${BIRDNET_DB}"
    print_simple_metric "db size" "${db_size}"
    print_simple_metric "processed ok" "${processed_ok}"
    print_simple_metric "processed error" "${processed_error}"
    print_simple_metric "pending upload" "${pending_uploads}"
}

print_audio_pipeline_summary() {
    local any_stage="false"

    path_within_target "${AUDIO_ROOT}" || return 0

    for stage_root in "${QUEUED_ROOT}" "${COMPRESSED_ROOT}" "${PROCESSED_ROOT}"; do
        if [[ -d "${stage_root}" ]]; then
            any_stage="true"
            break
        fi
    done

    [[ "${any_stage}" == "true" ]] || return 0

    printf '\n'
    print_header "Audio Pipeline"
    print_simple_metric "queued files" "$(stage_file_count "${QUEUED_ROOT}")"
    print_simple_metric "compressed files" "$(stage_file_count "${COMPRESSED_ROOT}")"
    print_simple_metric "processed files" "$(stage_file_count "${PROCESSED_ROOT}")"
    print_simple_metric "birdnet db" "$(if [[ -f "${BIRDNET_DB}" ]]; then printf 'present'; else printf 'missing'; fi)"

    print_stage_summary "Queued Stage" "${QUEUED_ROOT}"
    print_stage_summary "Compressed Stage" "${COMPRESSED_ROOT}"
    print_stage_summary "Processed Stage" "${PROCESSED_ROOT}"
    print_birdnet_db_summary
}

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --path)
                [[ $# -ge 2 ]] || {
                    echo "ERROR: --path requires an argument." >&2
                    exit 1
                }
                TARGET_PATH="$2"
                shift
                ;;
            --top)
                [[ $# -ge 2 ]] || {
                    echo "ERROR: --top requires an argument." >&2
                    exit 1
                }
                [[ "$2" =~ ^[1-9][0-9]*$ ]] || {
                    echo "ERROR: --top must be a positive integer." >&2
                    exit 1
                }
                TOP_N="$2"
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                echo "ERROR: unknown option: $1" >&2
                usage
                exit 1
                ;;
        esac
        shift
    done

    data_ops_require_cmd find
    data_ops_require_cmd du
    data_ops_require_cmd df
    data_ops_require_cmd sort
    data_ops_require_cmd head
    data_ops_require_cmd awk
    data_ops_require_cmd mountpoint

    require_dir "${TARGET_PATH}"

    print_filesystem_summary "${TARGET_PATH}"
    print_audio_pipeline_summary
    print_top_level_sizes "${TARGET_PATH}" "${TOP_N}"
    print_largest_files "${TARGET_PATH}" "${TOP_N}"
    print_recent_files "${TARGET_PATH}" "${TOP_N}"
}

main "$@"
