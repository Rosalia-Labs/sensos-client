#!/bin/bash
# SPDX-License-Identifier: MIT

set -euo pipefail

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
resolve_overlay_root() {
    printf '%s\n' "${SENSOS_CLIENT_ROOT:-/sensos}"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
CLIENT_ROOT="${SENSOS_CLIENT_ROOT:-${OVERLAY_ROOT}}"
script_name="$(basename "$0")"
PARSE_SWITCHES_LIB="${OVERLAY_ROOT}/libexec/parse-switches.sh"
SENSOS_ADMIN_HELPER_LIB="${OVERLAY_ROOT}/libexec/ensure-sensos-admin.sh"

[[ -f "${PARSE_SWITCHES_LIB}" ]] || {
    echo "Missing parse-switches library at ${PARSE_SWITCHES_LIB}"
    exit 1
}
source "${PARSE_SWITCHES_LIB}"
[[ -f "${SENSOS_ADMIN_HELPER_LIB}" ]] || {
    echo "Missing sensos-admin helper at ${SENSOS_ADMIN_HELPER_LIB}" >&2
    exit 1
}
source "${SENSOS_ADMIN_HELPER_LIB}"

ensure_sensos_admin_user "${SCRIPT_FILE}" "$@"

config_path="${CLIENT_ROOT}/etc/i2c-uploads.conf"
mkdir -p "${CLIENT_ROOT}/etc"

register_option --ownership-model ownership_model "Upload ownership model: client-retains or server-owns" "client-retains"
register_option --session-interval-sec session_interval_sec "Seconds between upload sessions" "1800"
register_option --batch-size batch_size "Maximum readings per upload batch" "500"
register_option --connect-timeout-sec connect_timeout_sec "HTTP connect timeout (seconds)" "10"
register_option --read-timeout-sec read_timeout_sec "HTTP read timeout (seconds)" "30"
register_option --delete-after-days delete_after_days "Delete local server-owned readings older than this many days" ""
register_option --enable-service enable_service "Enable systemd service" "false"
register_option --start-service start_service "Start systemd service" "false"
register_option --disable disable_service "Disable and stop systemd service" "false"

parse_switches "$script_name" "$@"

case "${ownership_model}" in
    client-retains|server-owns) ;;
    *)
        echo "Invalid --ownership-model: ${ownership_model}"
        echo "Expected: client-retains or server-owns"
        exit 1
        ;;
esac

if [[ -n "${delete_after_days}" && "${ownership_model}" != "server-owns" ]]; then
    echo "--delete-after-days requires --ownership-model server-owns"
    exit 1
fi

if [[ "$disable_service" == "true" && ( "$enable_service" == "true" || "$start_service" == "true" ) ]]; then
    echo "--disable cannot be combined with --enable-service or --start-service"
    exit 1
fi

{
    echo "# Auto-generated by ${script_name}"
    echo "OWNERSHIP_MODEL=${ownership_model}"
    echo "SESSION_INTERVAL_SEC=${session_interval_sec}"
    echo "BATCH_SIZE=${batch_size}"
    echo "CONNECT_TIMEOUT_SEC=${connect_timeout_sec}"
    echo "READ_TIMEOUT_SEC=${read_timeout_sec}"
    [[ -n "${delete_after_days}" ]] && echo "DELETE_AFTER_DAYS=${delete_after_days}"
} >"${config_path}"

echo "Wrote config to ${config_path}:"
cat "${config_path}"

output_dir="${CLIENT_ROOT}/data/microenv"
mkdir -p "${output_dir}"
sudo chown -R sensos-admin:sensos-data "${output_dir}"
sudo chmod -R 2775 "${output_dir}"

sudo systemctl daemon-reload
if [[ "${disable_service}" == "true" ]]; then
    echo "Disabling sensos-upload-i2c.service..."
    sudo systemctl disable --now sensos-upload-i2c.service || true
fi

if [[ "${enable_service}" == "true" ]]; then
    echo "Enabling sensos-upload-i2c.service..."
    sudo systemctl enable sensos-upload-i2c.service
    if sudo systemctl is-active --quiet sensos-upload-i2c.service; then
        echo "Restarting sensos-upload-i2c.service to apply new settings..."
        sudo systemctl restart sensos-upload-i2c.service
    fi
fi

if [[ "${start_service}" == "true" ]]; then
    echo "Starting sensos-upload-i2c.service..."
    sudo systemctl start sensos-upload-i2c.service
fi
