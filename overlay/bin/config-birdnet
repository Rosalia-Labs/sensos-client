#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

import argparse
import os
import subprocess
import sys
from pathlib import Path

CLIENT_ROOT = Path(os.environ.get("SENSOS_CLIENT_ROOT", "/sensos"))
CONFIG_FILE = CLIENT_ROOT / "etc" / "birdnet.env"
MODEL_ROOT = CLIENT_ROOT / "birdnet" / "BirdNET_v2.4_tflite"
SERVICE_NAME = "process-birdnet.service"
SETUP_HELPER = CLIENT_ROOT / "libexec" / "setup-birdnet.sh"
INSTALL_MODELS_CMD = "install-birdnet-models"
DEFAULT_BACKEND = "tensorflow"
BACKEND_ALIASES = {
    "tensorflow": "tensorflow",
    "litert": "litert",
    "tflite": "litert",
}


def run(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True)


def require_sensos_admin() -> None:
    if os.geteuid() == 0:
        return
    username = os.environ.get("USER") or run(["id", "-un"]).stdout.strip()
    if username != "sensos-admin":
        raise SystemExit("ERROR: this script must be run as sensos-admin or root.")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Configure optional host-native BirdNET processing."
    )
    parser.add_argument(
        "--disable",
        action="store_true",
        help="Disable BirdNET processing and stop the systemd service.",
    )
    parser.add_argument(
        "--enable-service",
        action="store_true",
        default=True,
        help="Enable process-birdnet.service after setup (default: true).",
    )
    parser.add_argument(
        "--start-service",
        action="store_true",
        help="Start process-birdnet.service after setup.",
    )
    parser.add_argument(
        "--download-models",
        action="store_true",
        help="Download and install the BirdNET model bundle before enabling BirdNET.",
    )
    parser.add_argument(
        "--models-url",
        help="Override the BirdNET model zip URL used with --download-models.",
    )
    parser.add_argument(
        "--backend",
        choices=["tensorflow", "litert", "tflite"],
        default=DEFAULT_BACKEND,
        help="BirdNET inference backend to install and require (default: tensorflow).",
    )
    return parser.parse_args()


def read_existing_backend() -> str:
    if not CONFIG_FILE.exists():
        return DEFAULT_BACKEND

    for line in CONFIG_FILE.read_text(encoding="utf-8").splitlines():
        if line.startswith("BIRDNET_BACKEND="):
            backend = line.split("=", 1)[1].strip()
            normalized = BACKEND_ALIASES.get(backend)
            if normalized is not None:
                return normalized

    return DEFAULT_BACKEND


def write_config(enabled: bool, backend: str) -> None:
    backend = BACKEND_ALIASES[backend]
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(
        (
            f"BIRDNET_ENABLED={'1' if enabled else '0'}\n"
            f"BIRDNET_BACKEND={backend}\n"
        ),
        encoding="utf-8",
    )


def ensure_models_present() -> None:
    required = [
        MODEL_ROOT / "audio-model.tflite",
        MODEL_ROOT / "labels" / "en_us.txt",
    ]
    missing = [str(path) for path in required if not path.exists()]
    if missing:
        joined = "\n  ".join(missing)
        raise SystemExit(
            "ERROR: BirdNET model files are missing:\n"
            f"  {joined}\n"
            "Place model files under /sensos/birdnet/BirdNET_v2.4_tflite before enabling BirdNET."
        )


def run_setup_step() -> None:
    if not SETUP_HELPER.exists():
        raise SystemExit(f"ERROR: missing BirdNET setup helper at {SETUP_HELPER}")
    result = subprocess.run(["sudo", str(SETUP_HELPER)])
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def install_models(url: str | None) -> None:
    cmd = [INSTALL_MODELS_CMD]
    if url:
        cmd.extend(["--url", url])
    result = subprocess.run(cmd)
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def systemctl(*args: str) -> None:
    result = subprocess.run(["sudo", "systemctl", *args])
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def main() -> int:
    require_sensos_admin()
    args = parse_args()

    if args.disable:
        write_config(False, read_existing_backend())
        systemctl("disable", "--now", SERVICE_NAME)
        print("BirdNET disabled.")
        return 0

    if args.download_models:
        install_models(args.models_url)

    ensure_models_present()
    selected_backend = BACKEND_ALIASES[args.backend]
    write_config(True, selected_backend)
    run_setup_step()

    if args.enable_service:
        systemctl("enable", SERVICE_NAME)
    if args.start_service:
        systemctl("start", SERVICE_NAME)

    print(f"BirdNET configured. Backend: {selected_backend}. Service: {SERVICE_NAME}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
