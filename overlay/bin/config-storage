#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_FILE}")" && pwd)"

resolve_overlay_root() {
    printf '%s\n' "${SENSOS_CLIENT_ROOT:-/sensos}"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
CLIENT_ROOT="${SENSOS_CLIENT_ROOT:-${OVERLAY_ROOT}}"

script_name="$(basename "$0")"
DATA_MOUNT="${CLIENT_ROOT}/data"
LOCATION_FILE="${CLIENT_ROOT}/etc/location.conf"
PARSE_SWITCHES_LIB="${OVERLAY_ROOT}/libexec/parse-switches.sh"
CACHE_SYS_INFO_SCRIPT="${OVERLAY_ROOT}/libexec/cache-sys-info.sh"
DATA_STORAGE_OPS_LIB="${OVERLAY_ROOT}/libexec/data-storage-ops.sh"
SENSOS_ADMIN_HELPER_LIB="${OVERLAY_ROOT}/libexec/ensure-sensos-admin.sh"
PARTED_BIN=""
PARTPROBE_BIN=""
MKFS_EXT4_BIN=""
PARTITION_ALREADY_MOUNTED_AT_DATA=0

[[ -f "${PARSE_SWITCHES_LIB}" ]] || {
    echo "❌ Missing parse-switches library at ${PARSE_SWITCHES_LIB}"
    exit 1
}
source "${PARSE_SWITCHES_LIB}"
[[ -f "${DATA_STORAGE_OPS_LIB}" ]] || {
    echo "❌ Missing data storage ops library at ${DATA_STORAGE_OPS_LIB}"
    exit 1
}
source "${DATA_STORAGE_OPS_LIB}"
[[ -f "${SENSOS_ADMIN_HELPER_LIB}" ]] || {
    echo "❌ Missing sensos-admin helper at ${SENSOS_ADMIN_HELPER_LIB}" >&2
    exit 1
}
source "${SENSOS_ADMIN_HELPER_LIB}"

ensure_sensos_admin_user "${SCRIPT_FILE}" "$@"

register_option --device device "Block device to format/mount" ""
register_option --wipe wipe "Create a new GPT table, make a single ext4 filesystem, and erase existing data" "false"
register_option --no-fstab no_fstab "Skip adding fstab entry (non-persistent mount)" "false"
register_option --yes yes "Skip interactive confirmations" "false"

parse_switches "$script_name" "$@"

is_interactive() {
    [[ -t 0 ]]
}

die() {
    echo "❌ $*" >&2
    exit 1
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

resolve_cmd_path() {
    local cmd_name="$1"
    local candidate=""

    if candidate="$(command -v "${cmd_name}" 2>/dev/null)"; then
        printf '%s\n' "${candidate}"
        return 0
    fi

    for candidate in "/usr/sbin/${cmd_name}" "/sbin/${cmd_name}" "/usr/bin/${cmd_name}" "/bin/${cmd_name}"; do
        if [[ -x "${candidate}" ]]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done

    return 1
}

require_storage_provisioning_tools() {
    local missing=()

    PARTED_BIN="$(resolve_cmd_path parted || true)"
    PARTPROBE_BIN="$(resolve_cmd_path partprobe || true)"
    MKFS_EXT4_BIN="$(resolve_cmd_path mkfs.ext4 || true)"

    [[ -n "${PARTED_BIN}" ]] || missing+=("parted")
    [[ -n "${PARTPROBE_BIN}" ]] || missing+=("partprobe")
    [[ -n "${MKFS_EXT4_BIN}" ]] || missing+=("mkfs.ext4")

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required storage provisioning command(s): ${missing[*]}. Run ./install or setup/01-packages first, or install the needed Debian packages such as parted and e2fsprogs."
    fi
}

ensure_data_layout() {
    local dir_path
    local -a required_dirs=(
        "${CLIENT_ROOT}/data"
        "${CLIENT_ROOT}/etc"
        "${CLIENT_ROOT}/log"
        "${CLIENT_ROOT}/data/audio_recordings"
        "${CLIENT_ROOT}/data/audio_recordings/queued"
        "${CLIENT_ROOT}/data/audio_recordings/compressed"
        "${CLIENT_ROOT}/data/audio_recordings/processed"
        "${CLIENT_ROOT}/data/birdnet"
    )

    echo "🔧 Ensuring SensOS data layout and permissions..."
    for dir_path in "${required_dirs[@]}"; do
        sudo mkdir -p "${dir_path}"
    done
    sudo chown -R sensos-admin:sensos-data "${CLIENT_ROOT}/data" "${CLIENT_ROOT}/etc" "${CLIENT_ROOT}/log"
    sudo chmod -R g+ws "${CLIENT_ROOT}/data" "${CLIENT_ROOT}/etc" "${CLIENT_ROOT}/log"
    sudo chmod -R +rX "${CLIENT_ROOT}/data" "${CLIENT_ROOT}/etc" "${CLIENT_ROOT}/log"
}

root_mount_source() {
    findmnt -n -o SOURCE / 2>/dev/null || true
}

root_backing_device() {
    local root_source
    local pkname

    root_source="$(root_mount_source)"
    [[ -n "${root_source}" ]] || return 0

    if [[ -b "${root_source}" ]]; then
        pkname="$(lsblk -no PKNAME "${root_source}" 2>/dev/null | head -n 1)"
        if [[ -n "${pkname}" ]]; then
            printf '/dev/%s\n' "${pkname}"
            return 0
        fi
        printf '%s\n' "${root_source}"
        return 0
    fi

    printf '%s\n' "${root_source}"
}

print_device_overview() {
    echo "Available block devices:"
    lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINTS,MODEL,SERIAL
    echo
    local root_source
    local root_device
    root_source="$(root_mount_source)"
    root_device="$(root_backing_device)"
    [[ -n "${root_source}" ]] && echo "⚠️  Root filesystem source: ${root_source}"
    [[ -n "${root_device}" && "${root_device}" != "${root_source}" ]] && echo "⚠️  Root backing disk: ${root_device}"
}

show_device_summary() {
    local target_device="$1"
    echo "Device summary for ${target_device}:"
    lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINTS,MODEL,SERIAL "${target_device}"
}

confirm_yes_no() {
    local prompt="$1"
    local default_yes="${2:-false}"
    local answer=""

    if [[ "${yes}" == "true" ]]; then
        return 0
    fi

    [[ "$(is_interactive; echo $?)" == "0" ]] || return 1

    if [[ "${default_yes}" == "true" ]]; then
        read -r -p "${prompt} [Y/n] " answer
        [[ "${answer}" != [nN] ]]
        return
    fi

    read -r -p "${prompt} [y/N] " answer
    [[ "${answer}" == [yY] ]]
}

prompt_for_device_selection() {
    local selection=""

    print_device_overview
    echo "Enter a device path such as /dev/vdb, or 'none' to keep ${DATA_MOUNT} on the current filesystem."
    while true; do
        read -r -p "Device to use [none]: " selection
        selection="${selection:-none}"
        if [[ "${selection}" == "none" ]]; then
            device=""
            return 0
        fi
        if [[ -b "${selection}" ]]; then
            device="${selection}"
            return 0
        fi
        echo "❌ '${selection}' is not a valid block device."
    done
}

require_device_or_prompt() {
    if [[ -n "${device}" ]]; then
        return 0
    fi

    if is_interactive; then
        prompt_for_device_selection
        return 0
    fi

    die "Missing required value: --device. Run interactively to choose a device, or pass --device <path>."
}

validate_target_device() {
    [[ -b "${device}" ]] || die "${device} is not a block device."

    local root_device
    root_device="$(root_backing_device)"
    if [[ -n "${root_device}" && "${device}" == "${root_device}" ]]; then
        die "${device} appears to back the running root filesystem. Refusing to modify it."
    fi
}

get_first_partition() {
    local target_device="$1"
    sudo lsblk -nrpo NAME,TYPE "${target_device}" | awk '$2 == "part" {print $1; exit}'
}

get_filesystem_type() {
    local part="$1"
    [[ -n "${part}" && -b "${part}" ]] || return 0
    sudo blkid -s TYPE -o value "${part}" 2>/dev/null || true
}

wait_for_partition() {
    local target_device="$1"
    local part=""
    local i
    for i in {1..10}; do
        part="$(get_first_partition "${target_device}")"
        if [[ -n "${part}" && -b "${part}" ]]; then
            printf '%s\n' "${part}"
            return 0
        fi
        sleep 0.5
    done
    return 1
}

partition_has_mounts() {
    local target="$1"
    findmnt -rn -S "${target}" >/dev/null 2>&1
}

unmount_path_if_needed() {
    local target="$1"
    if partition_has_mounts "${target}"; then
        echo "🔧 Unmounting ${target}..."
        sudo umount "${target}" || die "Failed to unmount ${target}."
    fi
}

prepare_disk_ext4() {
    local target_device="$1"

    require_storage_provisioning_tools

    echo "🛠️  Creating GPT partition table and a single ext4 filesystem on ${target_device}..."
    sudo "${PARTED_BIN}" -s "${target_device}" mklabel gpt
    sudo "${PARTED_BIN}" -s -a optimal "${target_device}" mkpart primary ext4 0% 100%
    sync
    sudo "${PARTPROBE_BIN}" "${target_device}" || sudo udevadm settle
    sleep 1

    PARTITION="$(wait_for_partition "${target_device}")" || die "Could not find partition on ${target_device}."
    echo "🧼 Creating ext4 filesystem on ${PARTITION}..."
    sudo "${MKFS_EXT4_BIN}" -F "${PARTITION}"
}

select_partition() {
    PARTITION="$(get_first_partition "${device}")"
    if [[ -n "${PARTITION}" ]]; then
        return 0
    fi

    if [[ "${wipe}" == "true" ]]; then
        prepare_disk_ext4 "${device}"
        return 0
    fi

    if is_interactive && confirm_yes_no "Create a new GPT table and ext4 filesystem on ${device}? This erases all data." true; then
        wipe="true"
        prepare_disk_ext4 "${device}"
        return 0
    fi

    die "No partition found on ${device}. Re-run with --wipe to create a new ext4 data disk."
}

ensure_partition_has_filesystem() {
    local fstype
    fstype="$(get_filesystem_type "${PARTITION}")"

    if [[ -n "${fstype}" ]]; then
        return 0
    fi

    if is_interactive && confirm_yes_no "No filesystem found on ${PARTITION}. Create a new ext4 filesystem? This erases all data on the partition." true; then
        require_storage_provisioning_tools
        echo "🧼 Creating ext4 filesystem on ${PARTITION}..."
        sudo "${MKFS_EXT4_BIN}" -F "${PARTITION}"
        return 0
    fi

    die "No filesystem found on ${PARTITION}. Re-run with --wipe or prepare the partition first."
}

clean_mountpoint_if_needed() {
    if [[ "${PARTITION_ALREADY_MOUNTED_AT_DATA}" == "1" ]]; then
        echo "ℹ️  ${PARTITION} is already mounted at ${DATA_MOUNT}; skipping mountpoint cleanup."
        return 0
    fi

    ensure_data_layout

    if [[ -n "$(sudo ls -A "${DATA_MOUNT}" 2>/dev/null)" ]]; then
        if [[ "${yes}" == "true" ]] || ( is_interactive && confirm_yes_no "${DATA_MOUNT} is not empty, and the new mount would hide its current contents. Remove the existing contents now so the mount can proceed?" false ); then
            echo "🧹 Removing existing contents from ${DATA_MOUNT}..."
            sudo find "${DATA_MOUNT}" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
            return 0
        fi
        die "${DATA_MOUNT} must be empty before mounting a separate data filesystem there. Clean it first, or rerun interactively and confirm removal."
    fi
}

mount_source_for_path() {
    local target_path="$1"
    findmnt -rn -o SOURCE --target "${target_path}" 2>/dev/null || true
}

resolve_existing_data_mount_state() {
    local current_source=""
    current_source="$(mount_source_for_path "${DATA_MOUNT}")"

    PARTITION_ALREADY_MOUNTED_AT_DATA=0
    [[ -n "${current_source}" ]] || return 0

    if [[ "${current_source}" == "${PARTITION}" ]]; then
        PARTITION_ALREADY_MOUNTED_AT_DATA=1
        return 0
    fi

    die "${DATA_MOUNT} is currently mounted from ${current_source}, not ${PARTITION}. Unmount or reconcile that mount first."
}

mount_partition() {
    if [[ "${PARTITION_ALREADY_MOUNTED_AT_DATA}" == "1" ]]; then
        echo "✅ Mount already in place: ${PARTITION} → ${DATA_MOUNT}"
        return 0
    fi

    echo "🔧 Mounting ${PARTITION} at ${DATA_MOUNT}..."
    sudo mount "${PARTITION}" "${DATA_MOUNT}"
    echo "✅ Mount complete: ${PARTITION} → ${DATA_MOUNT}"
}

persist_mount_if_requested() {
    local uuid
    local label
    local device_ref
    local fstype

    if [[ "${no_fstab}" == "true" ]]; then
        echo "⏭️  Skipping fstab update (flag --no-fstab was set)."
        return 0
    fi

    uuid="$(sudo blkid -s UUID -o value "${PARTITION}" 2>/dev/null || true)"
    label="$(sudo blkid -s LABEL -o value "${PARTITION}" 2>/dev/null || true)"
    fstype="$(get_filesystem_type "${PARTITION}")"
    [[ -n "${fstype}" ]] || fstype="ext4"

    if [[ -n "${uuid}" ]]; then
        device_ref="UUID=${uuid}"
    elif [[ -n "${label}" ]]; then
        device_ref="LABEL=${label}"
    else
        device_ref="${PARTITION}"
    fi

    echo "📄 Updating /etc/fstab for ${DATA_MOUNT}..."
    sudo sed -i.bak -r "\|^[^#].+\s+${DATA_MOUNT}\s+|d" /etc/fstab
    printf '%s %s %s defaults,nofail,noatime 0 2\n' "${device_ref}" "${DATA_MOUNT}" "${fstype}" | sudo tee -a /etc/fstab >/dev/null
    echo "✅ fstab updated"
}

write_storage_metadata() {
    echo "Creating device info on the mounted storage..."
    if [[ -x "${CACHE_SYS_INFO_SCRIPT}" ]]; then
        sudo "${CACHE_SYS_INFO_SCRIPT}" \
            --include "${CLIENT_ROOT}/etc/network.conf ${CLIENT_ROOT}/etc/location.conf ${CLIENT_ROOT}/etc/arecord.conf ${CLIENT_ROOT}/etc/i2c-sensors.conf ${CLIENT_ROOT}/etc/i2c-uploads.conf ${CLIENT_ROOT}/etc/birdnet-uploads.conf"
    else
        echo "ℹ️  cache-sys-info.sh not migrated yet; skipping storage metadata write."
    fi

    if [[ ! -f "${LOCATION_FILE}" ]] ||
        ! grep -q '^LATITUDE=' "${LOCATION_FILE}" ||
        ! grep -q '^LONGITUDE=' "${LOCATION_FILE}"; then
        echo
        echo "WARNING: device location is not configured."
        echo "The storage metadata was written, but it does not include a valid location."
        echo "Run: config-location --latitude <lat> --longitude <lon>"
        echo
    fi
}

finalize_mount_permissions() {
    sudo chown -R sensos-admin:sensos-data "${DATA_MOUNT}"
    sudo chmod -R 2775 "${DATA_MOUNT}"
    ensure_data_layout
}

main() {
    if data_ops_any_data_writer_active && ! data_ops_archive_mode_is_active; then
        echo "❌ Refusing to run ${script_name} while /sensos/data writers are active."
        echo "Enter archive mode first:"
        echo "  archive-mode --enter"
        echo "Then rerun ${script_name}."
        exit 1
    fi

    require_device_or_prompt

    if [[ -z "${device}" ]]; then
        ensure_data_layout
        echo "✅ SensOS data layout initialized under ${DATA_MOUNT}"
        exit 0
    fi

    validate_target_device
    show_device_summary "${device}"

    if [[ "${wipe}" != "true" && "${yes}" == "true" ]]; then
        die "--yes requires an explicit action. Re-run with --wipe for destructive provisioning."
    fi

    if [[ "${wipe}" == "true" ]]; then
        echo "⚠️  --wipe will erase existing partition and filesystem data on ${device}."
        if ! confirm_yes_no "Proceed with destructive reprovisioning of ${device}?" false; then
            die "Aborted."
        fi
    fi

    select_partition
    ensure_partition_has_filesystem
    resolve_existing_data_mount_state
    clean_mountpoint_if_needed
    mount_partition
    persist_mount_if_requested
    write_storage_metadata
    finalize_mount_permissions

    echo "✅ Storage configured at ${DATA_MOUNT}"
}

PARTITION=""
main "$@"
