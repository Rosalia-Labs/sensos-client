#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -e

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_FILE}")" && pwd)"
resolve_overlay_root() {
    printf '%s\n' "${SENSOS_CLIENT_ROOT:-/sensos}"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
CLIENT_ROOT="${SENSOS_CLIENT_ROOT:-${OVERLAY_ROOT}}"

script_name=$(basename "$0")
PARSE_SWITCHES_LIB="${OVERLAY_ROOT}/libexec/parse-switches.sh"

[[ -f "${PARSE_SWITCHES_LIB}" ]] || {
    echo "Missing parse-switches library at ${PARSE_SWITCHES_LIB}"
    exit 1
}
source "${PARSE_SWITCHES_LIB}"

warn_clock_and_location() {
    local clock_ok=0
    local location_ok=0
    local location_file="${CLIENT_ROOT}/etc/location.conf"

    if command -v timedatectl >/dev/null 2>&1; then
        if timedatectl show -p SystemClockSynchronized --value 2>/dev/null | grep -qi '^yes$'; then
            clock_ok=1
        elif timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -qi '^yes$'; then
            clock_ok=1
        fi
    fi

    if [[ -f "$location_file" ]] &&
        grep -q '^LATITUDE=' "$location_file" &&
        grep -q '^LONGITUDE=' "$location_file"; then
        location_ok=1
    fi

    if [[ "$clock_ok" -eq 1 && "$location_ok" -eq 1 ]]; then
        return
    fi

    echo
    echo "WARNING: device metadata is incomplete."
    [[ "$clock_ok" -eq 0 ]] && echo "  - System clock does not appear to be synchronized."
    [[ "$location_ok" -eq 0 ]] && echo "  - Device location has not been set in ${CLIENT_ROOT}/etc/location.conf."
    echo "Sensor readings may have incorrect timestamps or missing location context."
    echo "Recommended actions:"
    echo "  - Verify time sync before field deployment."
    echo "  - Run config-location --latitude <lat> --longitude <lon>."
    echo
}

config_path="${CLIENT_ROOT}/etc/i2c-sensors.conf"
mkdir -p "${CLIENT_ROOT}/etc"

register_option --interval interval "Default polling interval (seconds)" "60"
register_option --bme280-0x76-interval bme280_0x76_interval "Interval for BME280 at 0x76 (seconds)" ""
register_option --bme280-0x77-interval bme280_0x77_interval "Interval for BME280 at 0x77 (seconds)" ""
register_option --scd30-interval scd30_interval "Interval for SCD30 (seconds)" ""
register_option --scd4x-interval scd4x_interval "Interval for SCD4X (seconds)" ""
register_option --ads1015-interval ads1015_interval "Interval for ADS1015 (seconds)" ""
register_option --enable-service enable_service "Enable systemd service" "true"
register_option --start-service start_service "Start systemd service" "false"

parse_switches "$script_name" "$@"

{
    echo "# Auto-generated by $script_name"
    [[ -n "$interval" ]] && echo "INTERVAL_SEC=$interval"

    [[ -n "$bme280_0x76_interval" ]] && echo "BME280_0x76_INTERVAL_SEC=$bme280_0x76_interval"
    [[ -n "$bme280_0x77_interval" ]] && echo "BME280_0x77_INTERVAL_SEC=$bme280_0x77_interval"
    [[ -n "$scd30_interval" ]] && echo "SCD30_INTERVAL_SEC=$scd30_interval"
    [[ -n "$scd4x_interval" ]] && echo "SCD4X_INTERVAL_SEC=$scd4x_interval"
    [[ -n "$ads1015_interval" ]] && echo "ADS1015_INTERVAL_SEC=$ads1015_interval"
} >"$config_path"

echo "Wrote config to $config_path:"
cat "$config_path"

output_dir="${CLIENT_ROOT}/data/microenv"
mkdir -p "${output_dir}"
sudo chown -R sensos-admin:sensos-data "${output_dir}"
sudo chmod -R 2775 "${output_dir}"

echo "Ensuring optional I2C Python dependencies are installed..."
sudo "${CLIENT_ROOT}/libexec/setup-i2c-python.sh"

if [[ "$enable_service" == "true" ]]; then
    echo "Enabling sensos-read-i2c.service..."
    sudo systemctl daemon-reload
    sudo systemctl enable sensos-read-i2c.service
fi

if [[ "$start_service" == "true" ]]; then
    echo "Starting sensos-read-i2c.service..."
    sudo systemctl daemon-reload
    sudo systemctl start sensos-read-i2c.service
fi

warn_clock_and_location
