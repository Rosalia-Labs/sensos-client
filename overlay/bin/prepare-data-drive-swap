#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_FILE="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_FILE}")" && pwd)"
resolve_overlay_root() {
    local -a candidates=()
    local candidate

    if [[ -n "${SENSOS_CLIENT_ROOT:-}" ]]; then
        candidates+=("${SENSOS_CLIENT_ROOT}")
    fi

    candidates+=(
        "$(cd "${SCRIPT_DIR}/.." && pwd)"
        "/sensos"
    )

    for candidate in "${candidates[@]}"; do
        [[ -f "${candidate}/libexec/parse-switches.sh" ]] && {
            printf '%s\n' "${candidate}"
            return 0
        }
    done

    printf '%s\n' "$(cd "${SCRIPT_DIR}/.." && pwd)"
}

OVERLAY_ROOT="$(resolve_overlay_root)"
PARSE_SWITCHES_LIB="${OVERLAY_ROOT}/libexec/parse-switches.sh"
DATA_STORAGE_OPS_LIB="${OVERLAY_ROOT}/libexec/data-storage-ops.sh"

[[ -f "${PARSE_SWITCHES_LIB}" ]] || {
    echo "ERROR: missing parse-switches library at ${PARSE_SWITCHES_LIB}" >&2
    exit 1
}
source "${PARSE_SWITCHES_LIB}"
[[ -f "${DATA_STORAGE_OPS_LIB}" ]] || {
    echo "ERROR: missing data storage ops library at ${DATA_STORAGE_OPS_LIB}" >&2
    exit 1
}
source "${DATA_STORAGE_OPS_LIB}"

usage() {
    cat <<EOF
Usage: $(basename "$0")

Stop services using ${DATA_MOUNT} and determine whether the data media can be
swapped directly or whether data must be copied off the device instead.

Options:
  --undo true|false   Restore services after a dry run or aborted swap
EOF
}

main() {
    local root_source root_device data_source data_device undo

    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
        usage
        return 0
    fi

    register_option --undo undo "Restore services after a dry run or aborted swap" "false"
    parse_switches "$(basename "$0")" "$@"

    data_ops_require_cmd findmnt
    data_ops_require_cmd lsblk
    data_ops_require_cmd mountpoint
    data_ops_require_cmd sqlite3
    data_ops_require_cmd sync
    data_ops_require_cmd systemctl

    [[ -d "${DATA_MOUNT}" ]] || {
        echo "ERROR: data mount path not found: ${DATA_MOUNT}" >&2
        exit 1
    }

    if [[ "${undo}" == "true" ]]; then
        echo "Restoring ${DATA_MOUNT} after swap preparation..."
        if ! mountpoint -q "${DATA_MOUNT}"; then
            if ! data_ops_try_mount_data; then
                echo "ERROR: ${DATA_MOUNT} is not mounted and could not be remounted automatically." >&2
                echo "Run config-storage or mount ${DATA_MOUNT} manually, then rerun with --undo true." >&2
                exit 1
            fi
        fi
        data_ops_start_data_units
        echo "Restore complete."
        return 0
    fi

    echo "Preparing ${DATA_MOUNT} for shutdown or media swap..."
    data_ops_stop_data_units
    data_ops_checkpoint_sqlite_dbs
    data_ops_sync_storage

    root_source="$(data_ops_mount_source_for /)"
    root_device="$(data_ops_backing_device_for_source "${root_source}")"

    if ! mountpoint -q "${DATA_MOUNT}"; then
        echo
        echo "${DATA_MOUNT} is not a separate mountpoint."
        echo "Storage mode: root filesystem"
        echo "Root source: ${root_source:-unknown}"
        echo "Data under ${DATA_MOUNT} cannot be removed independently."
        echo "Copy data off the device instead of swapping media."
        return 0
    fi

    data_source="$(data_ops_mount_source_for "${DATA_MOUNT}")"
    data_device="$(data_ops_backing_device_for_source "${data_source}")"

    echo
    echo "Root source: ${root_source:-unknown}"
    echo "Data source: ${data_source:-unknown}"

    if [[ -z "${data_source}" || -z "${data_device}" ]]; then
        echo "Could not determine a removable backing device for ${DATA_MOUNT}."
        echo "Treat this as non-removable storage and copy data off the device instead."
        return 0
    fi

    if [[ -n "${root_device}" && "${data_device}" == "${root_device}" ]]; then
        echo "${DATA_MOUNT} shares the same backing device as / (${data_device})."
        echo "This media cannot be swapped independently."
        echo "Copy data off the device instead of removing storage."
        return 0
    fi

    echo "Unmounting ${DATA_MOUNT} from ${data_source}..."
    sudo umount "${DATA_MOUNT}"
    data_ops_sync_storage

    echo
    echo "Unmount complete."
    echo "Data device: ${data_device}"
    echo "It is now safe to power down and swap the media backing ${DATA_MOUNT}."
    echo "After swapping media, run config-storage to mount and prepare the replacement drive."
}

main "$@"
