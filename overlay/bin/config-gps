import argparse
import importlib.util
import os
import subprocess
import sys

SCRIPT_FILE = os.path.realpath(__file__)
SCRIPT_DIR = os.path.dirname(SCRIPT_FILE)
OVERLAY_ROOT = os.environ.get("SENSOS_CLIENT_ROOT", "/sensos")
CLIENT_ROOT = os.environ.get("SENSOS_CLIENT_ROOT", OVERLAY_ROOT)
UTILS_FILE = os.path.join(OVERLAY_ROOT, "libexec", "utils.py")

if not os.path.isfile(UTILS_FILE):
    raise RuntimeError(f"Missing utils.py at {UTILS_FILE}")

UTILS_SPEC = importlib.util.spec_from_file_location("sensos_overlay_utils", UTILS_FILE)
UTILS_MODULE = importlib.util.module_from_spec(UTILS_SPEC)
assert UTILS_SPEC.loader is not None
UTILS_SPEC.loader.exec_module(UTILS_MODULE)

parse_args_with_defaults = UTILS_MODULE.parse_args_with_defaults
create_dir = UTILS_MODULE.create_dir
write_file = UTILS_MODULE.write_file
ensure_sensos_admin = UTILS_MODULE.ensure_sensos_admin

CONFIG_PATH = os.path.join(CLIENT_ROOT, "etc", "gps.conf")
SERVICE_NAME = "sensos-gps.service"


def systemctl(*args: str) -> None:
    result = subprocess.run(["sudo", "systemctl", *args], check=False)
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def install_optional_python_dependencies() -> None:
    helper = os.path.join(CLIENT_ROOT, "libexec", "setup-gps-python.sh")
    if not os.path.isfile(helper):
        raise SystemExit(f"ERROR: missing GPS setup helper at {helper}")
    result = subprocess.run(["sudo", helper], check=False)
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def bool_text(value: bool) -> str:
    return "true" if value else "false"


def main() -> int:
    ensure_sensos_admin()
    arg_defs = [
        (["--disable"], {"action": "store_true", "help": "Disable GPS service and stop updates."}),
        (["--backend"], {"default": "i2c", "choices": ["i2c"], "help": "GPS backend type."}),
        (["--i2c-addr"], {"dest": "i2c_addr", "default": "0x10", "help": "I2C GPS address."}),
        (["--i2c-bus"], {"dest": "i2c_bus", "type": int, "default": 1, "help": "I2C bus number."}),
        (["--interval"], {"dest": "interval", "type": int, "default": 60, "help": "Polling interval in seconds."}),
        (["--sync-time"], {"dest": "sync_time", "action": argparse.BooleanOptionalAction, "default": True, "help": "Update system time from GPS if needed."}),
        (["--update-location"], {"dest": "update_location", "action": argparse.BooleanOptionalAction, "default": True, "help": "Update location.conf from GPS if needed."}),
        (["--location-drift-m"], {"dest": "location_drift_m", "type": float, "default": 50.0, "help": "Minimum movement before location.conf is updated."}),
        (["--time-conflict-sec"], {"dest": "time_conflict_sec", "type": float, "default": 300.0, "help": "If GPS and an already synchronized system clock differ by at least this many seconds, report a conflict instead of correcting time."}),
        (["--enable-service"], {"dest": "enable_service", "action": argparse.BooleanOptionalAction, "default": True, "help": "Enable the systemd service."}),
        (["--start-service"], {"dest": "start_service", "action": argparse.BooleanOptionalAction, "default": False, "help": "Start the systemd service now."}),
    ]
    args = parse_args_with_defaults(arg_defs, ["global", "config_gps"])

    create_dir(os.path.dirname(CONFIG_PATH), owner="sensos-admin", group="sensos-data", mode=0o2775)

    if args.disable:
        write_file(
            CONFIG_PATH,
            "GPS_ENABLED=false\n",
            mode=0o664,
            user="sensos-admin",
            group="sensos-data",
        )
        systemctl("disable", "--now", SERVICE_NAME)
        print("GPS disabled.")
        return 0

    content = (
        "GPS_ENABLED=true\n"
        f"GPS_BACKEND={args.backend}\n"
        f"GPS_I2C_ADDR={args.i2c_addr}\n"
        f"GPS_I2C_BUS={args.i2c_bus}\n"
        f"GPS_INTERVAL_SEC={args.interval}\n"
        f"GPS_SYNC_TIME={bool_text(args.sync_time)}\n"
        f"GPS_UPDATE_LOCATION={bool_text(args.update_location)}\n"
        f"GPS_LOCATION_DRIFT_M={args.location_drift_m}\n"
        f"GPS_TIME_CONFLICT_SEC={args.time_conflict_sec}\n"
    )
    write_file(CONFIG_PATH, content, mode=0o664, user="sensos-admin", group="sensos-data")
    print(f"Wrote GPS config to {CONFIG_PATH}")

    install_optional_python_dependencies()

    subprocess.run(["sudo", "systemctl", "daemon-reload"], check=False)
    if args.enable_service:
        systemctl("enable", SERVICE_NAME)
    if args.start_service:
        systemctl("start", SERVICE_NAME)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
