#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"
PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
INSTALL_STATE_FILE="${DEPLOY_ROOT}/etc/install-state.env"
REINSTALL=0
INSTALL_RECOMMENDS=0

log() {
    printf '[install] %s\n' "$*"
}

die() {
    printf '[install] ERROR: %s\n' "$*" >&2
    exit 1
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Configure the current machine as a SensOS client.

Options:
  --help             Show this help and exit
  --reinstall
                     Clear transient install artifacts before rerunning setup
  --install-recommends
                     Allow APT to install recommended packages during setup
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reinstall)
                REINSTALL=1
                ;;
            --install-recommends)
                INSTALL_RECOMMENDS=1
                ;;
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

ensure_not_root() {
    [[ "${EUID}" -ne 0 ]] || die "run ${SCRIPT_PATH} as the bootstrap user; it will use sudo for privileged steps"
}

confirm_install_target() {
    local reply

    printf 'WARNING: this will configure the current machine as a SensOS client and deploy into %s. Continue? [y/N] ' "${DEPLOY_ROOT}"
    read -r reply
    [[ "${reply}" =~ ^[Yy]$ ]] || die "installation cancelled"
}

sudo_run() {
    sudo env \
        "SENSOS_REPO_ROOT=${REPO_ROOT}" \
        "SENSOS_DEPLOY_ROOT=${DEPLOY_ROOT}" \
        "SENSOS_ALLOW_FRESH_INSTALL=1" \
        "SENSOS_EAGER_APT=1" \
        "SENSOS_EAGER_PIP=1" \
        "SENSOS_REINSTALL=${REINSTALL}" \
        "SENSOS_APT_INSTALL_RECOMMENDS=${INSTALL_RECOMMENDS}" \
        "$@"
}

verify_install_state() {
    sudo test -f "${INSTALL_STATE_FILE}" || \
        die "setup completed without writing ${INSTALL_STATE_FILE}"
}

read_install_flag() {
    local flag_name="$1"

    sudo awk -F= -v key="${flag_name}" '$1 == key { print $2 }' "${INSTALL_STATE_FILE}" 2>/dev/null || true
}

main() {
    parse_args "$@"
    ensure_not_root
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"
    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"

    confirm_install_target
    log "running setup into ${DEPLOY_ROOT}"
    sudo_run "${SETUP_SCRIPT}"
    verify_install_state
    if [[ "$(read_install_flag REBOOT_REQUIRED)" == "1" ]]; then
        log "install complete"
        log "REBOOT REQUIRED: Raspberry Pi hardware changes were applied but are not fully active yet"
        return
    fi
    log "install complete"
}

main "$@"
