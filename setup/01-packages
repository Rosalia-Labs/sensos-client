#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_CLIENT_ROOT:-${REPO_ROOT}}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
REQUIRED_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-required.txt"
DISCOURAGED_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-discouraged.txt"

log() {
    printf '[setup/01-packages] %s\n' "$*"
}

die() {
    printf '[setup/01-packages] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -f "${REQUIRED_PACKAGES_FILE}" ]] || die "missing ${REQUIRED_PACKAGES_FILE}"
    [[ -f "${DISCOURAGED_PACKAGES_FILE}" ]] || die "missing ${DISCOURAGED_PACKAGES_FILE}"
}

run_preflight() {
    log "running preflight"
    "${PRECHECK_SCRIPT}"
}

read_package_file() {
    local package_file="$1"
    grep -Ev '^\s*(#|$)' "${package_file}" || true
}

package_is_installed() {
    local package_name="$1"
    dpkg-query -W -f='${Status}\n' "${package_name}" 2>/dev/null | grep -Fxq 'install ok installed'
}

warn_discouraged_packages() {
    local warned=0
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        if package_is_installed "${package_name}"; then
            if [[ "${warned}" -eq 0 ]]; then
                log "detected discouraged packages from the old pi-gen removal list:"
                warned=1
            fi
            log "warning: installed discouraged package: ${package_name}"
        fi
    done < <(read_package_file "${DISCOURAGED_PACKAGES_FILE}")

    if [[ "${warned}" -eq 0 ]]; then
        log "no discouraged packages detected"
    fi
}

install_required_packages() {
    local packages=()
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        packages+=("${package_name}")
    done < <(read_package_file "${REQUIRED_PACKAGES_FILE}")

    [[ "${#packages[@]}" -gt 0 ]] || die "no packages listed in ${REQUIRED_PACKAGES_FILE}"

    log "updating apt package index"
    apt-get update

    log "installing required packages"
    apt-get install -y --no-install-recommends "${packages[@]}"
}

main() {
    require_root
    require_inputs
    run_preflight
    warn_discouraged_packages
    install_required_packages
}

main "$@"
