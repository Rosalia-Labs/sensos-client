#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
REQUIRED_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-required.txt"
REMOVE_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-remove.txt"
EAGER_APT="${SENSOS_EAGER_APT:-0}"
INSTALL_RECOMMENDS="${SENSOS_APT_INSTALL_RECOMMENDS:-0}"
OFFLINE="${SENSOS_OFFLINE:-0}"

log() {
    printf '[setup/01-packages] %s\n' "$*"
}

die() {
    printf '[setup/01-packages] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -f "${REQUIRED_PACKAGES_FILE}" ]] || die "missing ${REQUIRED_PACKAGES_FILE}"
    [[ -f "${REMOVE_PACKAGES_FILE}" ]] || die "missing ${REMOVE_PACKAGES_FILE}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

release_file_not_valid_yet() {
    local apt_output_file="$1"
    grep -Eq 'Release file .* is not valid yet' "${apt_output_file}"
}

try_clock_sync() {
    local synced=1

    if command -v timedatectl >/dev/null 2>&1; then
        if timedatectl set-ntp true >/dev/null 2>&1; then
            synced=0
        fi
    fi

    if command -v systemctl >/dev/null 2>&1; then
        systemctl restart chrony >/dev/null 2>&1 || true
        systemctl restart systemd-timesyncd >/dev/null 2>&1 || true
    fi

    if command -v chronyc >/dev/null 2>&1; then
        if chronyc -a makestep >/dev/null 2>&1; then
            synced=0
        fi
    fi

    if command -v ntpdate >/dev/null 2>&1; then
        if ntpdate -u pool.ntp.org >/dev/null 2>&1; then
            synced=0
        fi
    fi

    if sync_clock_from_http_date; then
        synced=0
    fi

    return "${synced}"
}

fetch_http_date_header() {
    local url="$1"
    local date_header=""

    if command -v curl >/dev/null 2>&1; then
        date_header="$(curl -fsSI --max-time 10 "${url}" 2>/dev/null | awk 'tolower($1)=="date:"{$1=""; sub(/^ /,""); print; exit}')"
    elif command -v wget >/dev/null 2>&1; then
        date_header="$(wget --server-response --spider -T 10 -t 1 "${url}" 2>&1 | awk 'tolower($1)=="date:"{$1=""; sub(/^ /,""); print; exit}')"
    fi

    [[ -n "${date_header}" ]] || return 1
    printf '%s\n' "${date_header}"
}

sync_clock_from_http_date() {
    local date_header
    local source_url
    local -a time_urls=(
        "http://deb.debian.org/debian/"
        "http://deb.debian.org/debian-security/"
        "http://archive.raspberrypi.com/debian/"
        "https://download.docker.com/linux/debian/"
    )

    for source_url in "${time_urls[@]}"; do
        date_header="$(fetch_http_date_header "${source_url}")" || continue
        if date -u -s "${date_header}" >/dev/null 2>&1; then
            log "set system clock from HTTP Date header at ${source_url}: ${date_header}"
            return 0
        fi
    done

    return 1
}

apt_update_with_clock_recovery() {
    local apt_output_file
    apt_output_file="$(mktemp)"

    if apt-get update 2> >(tee "${apt_output_file}" >&2); then
        rm -f "${apt_output_file}"
        return 0
    fi

    if ! release_file_not_valid_yet "${apt_output_file}"; then
        rm -f "${apt_output_file}"
        return 1
    fi

    log "apt metadata rejected as not valid yet; attempting clock sync and retry"
    if try_clock_sync; then
        sleep 3
    else
        log "no clock sync tool available; retrying apt update anyway"
    fi

    rm -f "${apt_output_file}"
    apt-get update
}

apt_install_args() {
    if [[ "${INSTALL_RECOMMENDS}" == "1" ]]; then
        printf '%s\n' "-y"
        return
    fi

    printf '%s\n' "-y"
    printf '%s\n' "--no-install-recommends"
}

read_package_file() {
    local package_file="$1"
    grep -Ev '^\s*(#|$)' "${package_file}" || true
}

package_is_available() {
    local package_name="$1"
    apt-cache show --no-all-versions "${package_name}" >/dev/null 2>&1
}

package_is_installed() {
    local package_name="$1"
    dpkg-query -W -f='${Status}\n' "${package_name}" 2>/dev/null | grep -Fxq 'install ok installed'
}

default_python3_version() {
    command -v python3 >/dev/null 2>&1 || return 1
    python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")'
}

expand_package_candidate() {
    local candidate="$1"
    local python_version

    case "${candidate}" in
        @python3-versioned-venv)
            python_version="$(default_python3_version)" || return 1
            printf 'python%s-venv\n' "${python_version}"
            ;;
        *)
            printf '%s\n' "${candidate}"
            ;;
    esac
}

resolve_package_spec() {
    local package_spec="$1"
    local candidate
    local -a package_candidates=()
    local expanded_candidate

    IFS='|' read -r -a package_candidates <<< "${package_spec}"

    for candidate in "${package_candidates[@]}"; do
        [[ -n "${candidate}" ]] || continue
        expanded_candidate="$(expand_package_candidate "${candidate}")" || continue
        if package_is_installed "${expanded_candidate}" || package_is_available "${expanded_candidate}"; then
            printf '%s\n' "${expanded_candidate}"
            return
        fi
    done

    die "no installable package found for spec '${package_spec}'"
}

collect_resolved_packages_from_file() {
    local package_file="$1"
    local package_spec
    local package_name

    while IFS= read -r package_spec; do
        [[ -n "${package_spec}" ]] || continue
        package_name="$(resolve_package_spec "${package_spec}")"
        printf '%s\n' "${package_name}"
    done < <(read_package_file "${package_file}")
}

collect_installed_packages_from_file() {
    local package_file="$1"
    local packages=()
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        if package_is_installed "${package_name}"; then
            packages+=("${package_name}")
        fi
    done < <(collect_resolved_packages_from_file "${package_file}")

    if [[ "${#packages[@]}" -gt 0 ]]; then
        printf '%s\n' "${packages[@]}"
    fi
}

remove_listed_packages() {
    local packages=("$@")

    [[ "${#packages[@]}" -gt 0 ]] || {
        log "no removable packages detected"
        return
    }

    log "removing packages listed in ${REMOVE_PACKAGES_FILE}"
    apt-get purge -y "${packages[@]}"
    apt-get autoremove -y
}

collect_missing_required_packages() {
    local packages=()
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        if ! package_is_installed "${package_name}"; then
            packages+=("${package_name}")
        fi
    done < <(collect_resolved_packages_from_file "${REQUIRED_PACKAGES_FILE}")

    if [[ "${#packages[@]}" -gt 0 ]]; then
        printf '%s\n' "${packages[@]}"
    fi
}

package_spec_is_installed() {
    local package_spec="$1"
    local candidate
    local -a package_candidates=()
    local expanded_candidate

    IFS='|' read -r -a package_candidates <<< "${package_spec}"

    for candidate in "${package_candidates[@]}"; do
        [[ -n "${candidate}" ]] || continue
        expanded_candidate="$(expand_package_candidate "${candidate}")" || continue
        if package_is_installed "${expanded_candidate}"; then
            return 0
        fi
    done

    return 1
}

collect_missing_required_package_specs() {
    local package_spec

    while IFS= read -r package_spec; do
        [[ -n "${package_spec}" ]] || continue
        if ! package_spec_is_installed "${package_spec}"; then
            printf '%s\n' "${package_spec}"
        fi
    done < <(read_package_file "${REQUIRED_PACKAGES_FILE}")
}

install_required_packages() {
    local packages=("$@")
    local apt_args=()

    [[ "${#packages[@]}" -gt 0 ]] || {
        log "all required packages already installed"
        return
    }

    log "installing missing required packages"
    mapfile -t apt_args < <(apt_install_args)
    apt-get install "${apt_args[@]}" "${packages[@]}"
}

main() {
    local remove_packages=()
    local install_packages=()
    local required_packages=()
    local missing_specs=()
    local apt_args=()

    require_root
    require_inputs
    run_preflight

    mapfile -t remove_packages < <(collect_installed_packages_from_file "${REMOVE_PACKAGES_FILE}")
    mapfile -t install_packages < <(collect_missing_required_packages)

    if [[ "${OFFLINE}" == "1" ]]; then
        mapfile -t missing_specs < <(collect_missing_required_package_specs)
        if [[ "${#missing_specs[@]}" -gt 0 ]]; then
            printf '[setup/01-packages] offline mode is missing required packages:\n' >&2
            printf '  %s\n' "${missing_specs[@]}" >&2
            die "install the required Debian packages before rerunning in offline mode, or rerun without --offline once internet is available"
        fi

        if [[ "${#remove_packages[@]}" -gt 0 ]]; then
            log "offline mode enabled; skipping package removals"
        fi
        log "offline mode enabled; required Debian packages already installed, skipping apt operations"
        return
    fi

    if [[ "${EAGER_APT}" == "1" ]]; then
        log "eager APT mode enabled; refreshing package index"
        apt_update_with_clock_recovery
        remove_listed_packages "${remove_packages[@]}"
        mapfile -t required_packages < <(collect_resolved_packages_from_file "${REQUIRED_PACKAGES_FILE}")
        log "installing required packages"
        mapfile -t apt_args < <(apt_install_args)
        apt-get install "${apt_args[@]}" "${required_packages[@]}"
        return
    fi

    if [[ "${#remove_packages[@]}" -eq 0 && "${#install_packages[@]}" -eq 0 ]]; then
        log "package state already converged; skipping apt operations"
        return
    fi

    log "updating apt package index"
    apt_update_with_clock_recovery

    remove_listed_packages "${remove_packages[@]}"
    install_required_packages "${install_packages[@]}"
}

main "$@"
