#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
REQUIRED_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-required.txt"
REMOVE_PACKAGES_FILE="${CLIENT_ROOT}/setup/packages-remove.txt"

log() {
    printf '[setup/01-packages] %s\n' "$*"
}

die() {
    printf '[setup/01-packages] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -f "${REQUIRED_PACKAGES_FILE}" ]] || die "missing ${REQUIRED_PACKAGES_FILE}"
    [[ -f "${REMOVE_PACKAGES_FILE}" ]] || die "missing ${REMOVE_PACKAGES_FILE}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

read_package_file() {
    local package_file="$1"
    grep -Ev '^\s*(#|$)' "${package_file}" || true
}

package_is_installed() {
    local package_name="$1"
    dpkg-query -W -f='${Status}\n' "${package_name}" 2>/dev/null | grep -Fxq 'install ok installed'
}

collect_installed_packages_from_file() {
    local package_file="$1"
    local packages=()
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        if package_is_installed "${package_name}"; then
            packages+=("${package_name}")
        fi
    done < <(read_package_file "${package_file}")

    printf '%s\n' "${packages[@]}"
}

remove_listed_packages() {
    local packages=("$@")

    [[ "${#packages[@]}" -gt 0 ]] || {
        log "no removable packages detected"
        return
    }

    log "removing packages listed in ${REMOVE_PACKAGES_FILE}"
    apt-get purge -y "${packages[@]}"
    apt-get autoremove -y
}

collect_missing_required_packages() {
    local packages=()
    local package_name

    while IFS= read -r package_name; do
        [[ -n "${package_name}" ]] || continue
        if ! package_is_installed "${package_name}"; then
            packages+=("${package_name}")
        fi
    done < <(read_package_file "${REQUIRED_PACKAGES_FILE}")

    printf '%s\n' "${packages[@]}"
}

install_required_packages() {
    local packages=("$@")

    [[ "${#packages[@]}" -gt 0 ]] || {
        log "all required packages already installed"
        return
    }

    log "installing missing required packages"
    apt-get install -y --no-install-recommends "${packages[@]}"
}

main() {
    local remove_packages=()
    local install_packages=()

    require_root
    require_inputs
    run_preflight

    mapfile -t remove_packages < <(collect_installed_packages_from_file "${REMOVE_PACKAGES_FILE}")
    mapfile -t install_packages < <(collect_missing_required_packages)

    if [[ "${#remove_packages[@]}" -eq 0 && "${#install_packages[@]}" -eq 0 ]]; then
        log "package state already converged; skipping apt operations"
        return
    fi

    log "updating apt package index"
    apt-get update

    remove_listed_packages "${remove_packages[@]}"
    install_required_packages "${install_packages[@]}"
}

main "$@"
