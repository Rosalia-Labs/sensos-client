#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
OVERLAY_SYSTEMD_DIR="${CLIENT_ROOT}/overlay/systemd"
INSTALL_STATE_FILE="${DEPLOY_ROOT}/etc/install-state.env"
ARECORD_CONF_FILE="${DEPLOY_ROOT}/etc/arecord.conf"

HOST_BASELINE_UNITS=(
    sensos-monitor-data-space.timer
    nftables.service
    ssh.service
    vnstat.service
)

RETIRED_UNITS=(
    monitor-data-space.timer
    send-status-update.timer
    monitor-data-space.service
    send-status-update.service
    thin-data.service
    sensos-arecord.service
    senoss-monitor-data-space.timer
    senoss-send-status-update.timer
    senoss-monitor-data-space.service
    senoss-send-status-update.service
    senoss-thin-data.service
    senoss-arecord.service
    senoss-birdnet.service
    senoss-compress-audio.service
    senoss-gps.service
    senoss-network-capture.service
    senoss-read-i2c.service
    senoss-upload-i2c.service
)

OPTIONAL_AUDIO_UNITS=(
    sensos-record-audio.service
    sensos-thin-data.service
)

ALWAYS_ON_SENSOS_UNITS=(
    sensos-compress-audio.service
)

RESTART_SAFE_SENSOS_UNITS=(
    sensos-record-audio.service
    sensos-compress-audio.service
    sensos-thin-data.service
    sensos-birdnet.service
    sensos-upload-birdnet.service
    sensos-read-i2c.service
    sensos-upload-i2c.service
    sensos-gps.service
)

log() {
    printf '[setup/07-services] %s\n' "$*"
}

die() {
    printf '[setup/07-services] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -d "${OVERLAY_SYSTEMD_DIR}" ]] || die "missing overlay systemd directory: ${OVERLAY_SYSTEMD_DIR}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

require_systemctl() {
    command -v systemctl >/dev/null 2>&1 || die "systemctl not found"
}

enable_host_unit_if_present() {
    local unit_name="$1"

    if [[ "${unit_name}" == "nftables.service" && ! -f /etc/nftables.conf ]]; then
        log "nftables config not present; skipped ${unit_name}"
        return
    fi

    if systemctl list-unit-files --type=service --type=timer 2>/dev/null | awk '{print $1}' | grep -Fxq "${unit_name}"; then
        systemctl enable "${unit_name}"
        if systemctl is-active --quiet "${unit_name}"; then
            systemctl restart "${unit_name}"
            log "restarted host unit ${unit_name}"
        else
            systemctl start "${unit_name}"
            log "started host unit ${unit_name}"
        fi
        log "enabled host unit ${unit_name}"
    else
        log "host unit not present; skipped ${unit_name}"
    fi
}

describe_host_unit_state() {
    local unit_name="$1"
    local enabled_state="unknown"
    local active_state="inactive"

    if ! systemctl list-unit-files --type=service --type=timer 2>/dev/null | awk '{print $1}' | grep -Fxq "${unit_name}"; then
        log "host unit not present; skipped ${unit_name}"
        return 0
    fi

    enabled_state="$(systemctl is-enabled "${unit_name}" 2>/dev/null || printf 'unknown')"
    if systemctl is-active --quiet "${unit_name}"; then
        active_state="active"
    fi

    log "preserved host unit ${unit_name}: enabled=${enabled_state} active=${active_state}"
}

disable_host_unit_if_present() {
    local unit_name="$1"
    local log_absent="${2:-yes}"

    if systemctl list-unit-files --type=service --type=timer 2>/dev/null | awk '{print $1}' | grep -Fxq "${unit_name}"; then
        systemctl disable --now "${unit_name}" >/dev/null 2>&1 || true
        log "disabled host unit ${unit_name}"
    elif [[ "${log_absent}" == "yes" ]]; then
        log "host unit not present; skipped ${unit_name}"
    fi
}

retire_old_units() {
    local unit_name

    for unit_name in "${RETIRED_UNITS[@]}"; do
        disable_host_unit_if_present "${unit_name}" "no"
    done
}

ensure_enabled_sensos_unit_if_present() {
    local unit_name="$1"

    if ! systemctl list-unit-files --type=service --type=timer 2>/dev/null | awk '{print $1}' | grep -Fxq "${unit_name}"; then
        log "host unit not present; skipped ${unit_name}"
        return 0
    fi

    systemctl enable "${unit_name}"
    if systemctl is-active --quiet "${unit_name}"; then
        systemctl restart "${unit_name}"
        log "restarted enabled SensOS unit ${unit_name}"
    else
        systemctl start "${unit_name}"
        log "started enabled SensOS unit ${unit_name}"
    fi
}

reconcile_always_on_sensos_units() {
    local unit_name

    log "ensuring always-on SensOS worker units are enabled and running"
    for unit_name in "${ALWAYS_ON_SENSOS_UNITS[@]}"; do
        ensure_enabled_sensos_unit_if_present "${unit_name}"
    done
}

reconcile_optional_audio_units() {
    local unit_name

    if [[ -f "${ARECORD_CONF_FILE}" ]]; then
        log "audio configuration present at ${ARECORD_CONF_FILE}; preserving optional audio unit state"
        for unit_name in "${OPTIONAL_AUDIO_UNITS[@]}"; do
            describe_host_unit_state "${unit_name}"
        done
        return
    fi

    log "audio configuration absent at ${ARECORD_CONF_FILE}; disabling optional audio units"
    for unit_name in "${OPTIONAL_AUDIO_UNITS[@]}"; do
        disable_host_unit_if_present "${unit_name}"
    done
}

restart_active_sensos_unit_if_present() {
    local unit_name="$1"
    local enabled_state="unknown"

    if ! systemctl list-unit-files --type=service --type=timer 2>/dev/null | awk '{print $1}' | grep -Fxq "${unit_name}"; then
        log "host unit not present; skipped ${unit_name}"
        return 0
    fi

    enabled_state="$(systemctl is-enabled "${unit_name}" 2>/dev/null || printf 'unknown')"

    if [[ "${enabled_state}" != "enabled" ]]; then
        log "left non-enabled SensOS unit unchanged: ${unit_name} (enabled=${enabled_state})"
        return 0
    fi

    if systemctl is-active --quiet "${unit_name}"; then
        systemctl restart "${unit_name}"
        log "restarted active SensOS unit ${unit_name}"
    else
        log "left enabled but inactive SensOS unit unchanged: ${unit_name}"
    fi
}

reconcile_restart_safe_sensos_units() {
    local unit_name

    log "restarting active restart-safe SensOS worker units"
    for unit_name in "${RESTART_SAFE_SENSOS_UNITS[@]}"; do
        restart_active_sensos_unit_if_present "${unit_name}"
    done
}

main() {
    local unit_name

    require_root
    require_inputs
    run_preflight
    require_systemctl

    systemctl daemon-reload
    log "reloaded systemd unit files"
    retire_old_units

    if [[ -f "${INSTALL_STATE_FILE}" ]]; then
        log "existing install detected at ${INSTALL_STATE_FILE}; preserving host unit state"
        for unit_name in "${HOST_BASELINE_UNITS[@]}"; do
            describe_host_unit_state "${unit_name}"
        done
        reconcile_always_on_sensos_units
        reconcile_optional_audio_units
        reconcile_restart_safe_sensos_units
    else
        log "fresh install detected; reconciling optional audio unit state"
        reconcile_always_on_sensos_units
        reconcile_optional_audio_units
        for unit_name in "${HOST_BASELINE_UNITS[@]}"; do
            enable_host_unit_if_present "${unit_name}"
        done
    fi
}

main "$@"
