#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
OVERLAY_ROOT="${CLIENT_ROOT}/overlay"

OVERLAY_BIN_DIR="${OVERLAY_ROOT}/bin"
OVERLAY_ETC_DIR="${OVERLAY_ROOT}/etc"
OVERLAY_LIBEXEC_DIR="${OVERLAY_ROOT}/libexec"
OVERLAY_PROFILES_DIR="${OVERLAY_ROOT}/profiles"
OVERLAY_SYSTEMD_DIR="${OVERLAY_ROOT}/systemd"
BIRDNET_REQUIREMENTS_SOURCE="${CLIENT_ROOT}/python/requirements-birdnet.txt"
I2C_REQUIREMENTS_SOURCE="${CLIENT_ROOT}/python/requirements-i2c.txt"
GPS_REQUIREMENTS_SOURCE="${CLIENT_ROOT}/python/requirements-gps.txt"

DEPLOY_ETC_DIR="${DEPLOY_ROOT}/etc"
DEPLOY_LIBEXEC_DIR="${DEPLOY_ROOT}/libexec"
DEPLOY_PROFILES_DIR="${DEPLOY_ROOT}/profiles"
LEGACY_DEPLOY_BIN_DIR="${DEPLOY_ROOT}/bin"
LEGACY_DEPLOY_SYSTEMD_DIR="${DEPLOY_ROOT}/systemd"

HOST_BIN_DIR="/usr/local/bin"
HOST_SYSTEMD_DIR="/etc/systemd/system"

log() {
    printf '[setup/05-overlay] %s\n' "$*"
}

die() {
    printf '[setup/05-overlay] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -d "${OVERLAY_ROOT}" ]] || die "missing overlay directory: ${OVERLAY_ROOT}"
    [[ -d "${OVERLAY_SYSTEMD_DIR}" ]] || die "missing overlay systemd directory: ${OVERLAY_SYSTEMD_DIR}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

ensure_host_dirs() {
    install -d -m 0755 "${HOST_BIN_DIR}"
    install -d -m 0755 "${HOST_SYSTEMD_DIR}"
}

ensure_deploy_dirs() {
    install -d -m 2775 "${DEPLOY_ROOT}"
    install -d -m 2775 "${DEPLOY_ETC_DIR}"
    install -d -m 2775 "${DEPLOY_LIBEXEC_DIR}"
    install -d -m 2775 "${DEPLOY_PROFILES_DIR}"
}

install_birdnet_requirements() {
    if [[ -f "${BIRDNET_REQUIREMENTS_SOURCE}" ]]; then
        install -m 0644 "${BIRDNET_REQUIREMENTS_SOURCE}" "${DEPLOY_ETC_DIR}/birdnet-requirements.txt"
        log "installed ${DEPLOY_ETC_DIR}/birdnet-requirements.txt from ${BIRDNET_REQUIREMENTS_SOURCE}"
    else
        log "no BirdNET requirements file found at ${BIRDNET_REQUIREMENTS_SOURCE}; skipping"
    fi
}

install_i2c_requirements() {
    if [[ -f "${I2C_REQUIREMENTS_SOURCE}" ]]; then
        install -m 0644 "${I2C_REQUIREMENTS_SOURCE}" "${DEPLOY_ETC_DIR}/i2c-requirements.txt"
        log "installed ${DEPLOY_ETC_DIR}/i2c-requirements.txt from ${I2C_REQUIREMENTS_SOURCE}"
    else
        log "no I2C requirements file found at ${I2C_REQUIREMENTS_SOURCE}; skipping"
    fi
}

install_gps_requirements() {
    if [[ -f "${GPS_REQUIREMENTS_SOURCE}" ]]; then
        install -m 0644 "${GPS_REQUIREMENTS_SOURCE}" "${DEPLOY_ETC_DIR}/gps-requirements.txt"
        log "installed ${DEPLOY_ETC_DIR}/gps-requirements.txt from ${GPS_REQUIREMENTS_SOURCE}"
    else
        log "no GPS requirements file found at ${GPS_REQUIREMENTS_SOURCE}; skipping"
    fi
}

purge_target_dir() {
    local target_dir="$1"
    local target_path

    [[ -d "${target_dir}" ]] || return 0

    while IFS= read -r target_path; do
        rm -f "${target_path}"
    done < <(find "${target_dir}" -mindepth 1 -maxdepth 1 \( -type f -o -type l \))
}

install_dir_entries() {
    local source_dir="$1"
    local target_dir="$2"
    local mode="$3"
    local purge_existing="${4:-yes}"
    local source_path

    [[ -d "${source_dir}" ]] || return 0

    if [[ "${purge_existing}" == "yes" ]]; then
        purge_target_dir "${target_dir}"
    fi

    while IFS= read -r source_path; do
        install -m "${mode}" "${source_path}" "${target_dir}/$(basename "${source_path}")"
        log "installed ${target_dir}/$(basename "${source_path}") from ${source_path}"
    done < <(find "${source_dir}" -maxdepth 1 -type f ! -name '.gitkeep' | sort)
}

remove_managed_host_symlinks() {
    local source_dir="$1"
    local target_dir="$2"
    local target_path
    local resolved_path

    [[ -d "${target_dir}" ]] || return 0

    while IFS= read -r target_path; do
        resolved_path="$(readlink "${target_path}")"
        if [[ "${resolved_path}" == "${source_dir}/"* ]]; then
            rm -f "${target_path}"
            log "removed stale managed link ${target_path}"
        fi
    done < <(find "${target_dir}" -maxdepth 1 -type l | sort)
}

retire_legacy_deploy_dir() {
    local target_dir="$1"

    [[ -e "${target_dir}" ]] || return 0
    rm -rf "${target_dir}"
    log "removed retired legacy deployment directory ${target_dir}"
}

remove_legacy_symlinks() {
    remove_managed_host_symlinks "${LEGACY_DEPLOY_BIN_DIR}" "${HOST_BIN_DIR}"
    remove_managed_host_symlinks "${LEGACY_DEPLOY_SYSTEMD_DIR}" "${HOST_SYSTEMD_DIR}"
}

install_host_entries() {
    local source_dir="$1"
    local target_dir="$2"
    local mode="$3"
    local source_path

    [[ -d "${source_dir}" ]] || return 0

    while IFS= read -r source_path; do
        install -m "${mode}" "${source_path}" "${target_dir}/$(basename "${source_path}")"
        log "installed ${target_dir}/$(basename "${source_path}") from ${source_path}"
    done < <(find "${source_dir}" -maxdepth 1 -type f ! -name '.gitkeep' | sort)
}

reload_systemd() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl daemon-reload
        log "reloaded systemd unit files"
    else
        log "systemctl not found; skipped daemon-reload"
    fi
}

main() {
    require_root
    require_inputs
    run_preflight
    ensure_deploy_dirs
    ensure_host_dirs
    install_dir_entries "${OVERLAY_ETC_DIR}" "${DEPLOY_ETC_DIR}" 0644 no
    install_dir_entries "${OVERLAY_LIBEXEC_DIR}" "${DEPLOY_LIBEXEC_DIR}" 0755 yes
    install_dir_entries "${OVERLAY_PROFILES_DIR}" "${DEPLOY_PROFILES_DIR}" 0644 yes
    install_birdnet_requirements
    install_i2c_requirements
    install_gps_requirements
    remove_legacy_symlinks
    install_host_entries "${OVERLAY_BIN_DIR}" "${HOST_BIN_DIR}" 0755
    install_host_entries "${OVERLAY_SYSTEMD_DIR}" "${HOST_SYSTEMD_DIR}" 0644
    retire_legacy_deploy_dir "${LEGACY_DEPLOY_BIN_DIR}"
    retire_legacy_deploy_dir "${LEGACY_DEPLOY_SYSTEMD_DIR}"
    reload_systemd
}

main "$@"
