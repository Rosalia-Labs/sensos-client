#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
REQUIREMENTS_FILE="${CLIENT_ROOT}/python/requirements.txt"
VENV_DIR="${DEPLOY_ROOT}/python/venv"
REQUIREMENTS_STAMP_FILE="${VENV_DIR}/.requirements.sha256"
PYTHON_BIN="${PYTHON_BIN:-python3}"
EAGER_PIP="${SENSOS_EAGER_PIP:-0}"

SENSOS_ADMIN_USER="sensos-admin"
SENSOS_DATA_GROUP="sensos-data"

log() {
    printf '[setup/04-python-venv] %s\n' "$*"
}

die() {
    printf '[setup/04-python-venv] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -f "${REQUIREMENTS_FILE}" ]] || die "missing ${REQUIREMENTS_FILE}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

require_identity() {
    id -u "${SENSOS_ADMIN_USER}" >/dev/null 2>&1 || die "missing user ${SENSOS_ADMIN_USER}; run setup/02-users first"
    getent group "${SENSOS_DATA_GROUP}" >/dev/null 2>&1 || die "missing group ${SENSOS_DATA_GROUP}; run setup/02-users first"
}

require_python() {
    command -v "${PYTHON_BIN}" >/dev/null 2>&1 || die "missing ${PYTHON_BIN}; run setup/01-packages first"
}

required_system_venv_package() {
    "${PYTHON_BIN}" -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}-venv")'
}

python_can_create_venv() {
    local probe_dir
    probe_dir="$(mktemp -d "${DEPLOY_ROOT}/python/venv-probe.XXXXXX")"

    if "${PYTHON_BIN}" -m venv "${probe_dir}" >/dev/null 2>&1; then
        rm -rf "${probe_dir}"
        return 0
    fi

    rm -rf "${probe_dir}"
    return 1
}

ensure_system_venv_support() {
    local venv_package

    if python_can_create_venv; then
        return
    fi

    venv_package="$(required_system_venv_package)"
    log "installing ${venv_package} so ${PYTHON_BIN} can create virtual environments"
    apt-get install -y "${venv_package}"

    python_can_create_venv || die "${PYTHON_BIN} still cannot create a virtual environment after installing ${venv_package}"
}

ensure_python_layout() {
    install -d "${DEPLOY_ROOT}/python"
}

ensure_venv() {
    if [[ ! -x "${VENV_DIR}/bin/python" ]]; then
        log "creating virtual environment at ${VENV_DIR}"
        "${PYTHON_BIN}" -m venv "${VENV_DIR}"
        VENV_CREATED=1
    else
        log "reusing existing virtual environment at ${VENV_DIR}"
        VENV_CREATED=0
    fi
}

required_venv_package() {
    "${VENV_DIR}/bin/python" -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}-venv")'
}

ensure_venv_pip() {
    local venv_package

    if "${VENV_DIR}/bin/python" -m pip --version >/dev/null 2>&1; then
        return
    fi

    log "bootstrapping pip in ${VENV_DIR}"
    venv_package="$(required_venv_package)"
    "${VENV_DIR}/bin/python" -m ensurepip --upgrade >/dev/null 2>&1 || \
        die "pip is unavailable in ${VENV_DIR}; install ${venv_package} and retry"
}

requirements_declared() {
    grep -Eq '^\s*[^#[:space:]]' "${REQUIREMENTS_FILE}"
}

requirement_declared() {
    local requirement_name="$1"
    grep -Eiq "^\s*${requirement_name}([[:space:]]*([<>=!~].*)?)?\s*$" "${REQUIREMENTS_FILE}"
}

ensure_python_build_support() {
    if ! requirement_declared "lgpio"; then
        return
    fi

    if command -v swig >/dev/null 2>&1; then
        return
    fi

    log "installing swig for lgpio wheel build"
    apt-get install -y swig
    command -v swig >/dev/null 2>&1 || die "swig is still unavailable after apt install"
}

requirements_digest() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "${REQUIREMENTS_FILE}" | awk '{print $1}'
        return
    fi

    if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "${REQUIREMENTS_FILE}" | awk '{print $1}'
        return
    fi

    die "missing sha256sum/shasum; cannot track Python requirements state"
}

install_requirements_if_needed() {
    local current_digest
    local previous_digest=""

    current_digest="$(requirements_digest)"
    if [[ -f "${REQUIREMENTS_STAMP_FILE}" ]]; then
        previous_digest="$(head -n 1 "${REQUIREMENTS_STAMP_FILE}" | tr -d '[:space:]')"
    fi

    if [[ "${EAGER_PIP}" == "1" ]]; then
        if requirements_declared; then
            log "eager pip mode enabled; installing Python dependencies from ${REQUIREMENTS_FILE}"
            "${VENV_DIR}/bin/python" -m pip install -r "${REQUIREMENTS_FILE}"
        else
            log "eager pip mode enabled but no Python requirements declared; skipping pip"
        fi
        printf '%s\n' "${current_digest}" >"${REQUIREMENTS_STAMP_FILE}"
        return
    fi

    if [[ "${VENV_CREATED}" -eq 0 && "${current_digest}" == "${previous_digest}" ]]; then
        log "Python requirements unchanged; skipping pip"
        return
    fi

    if requirements_declared; then
        log "installing Python dependencies from ${REQUIREMENTS_FILE}"
        "${VENV_DIR}/bin/python" -m pip install -r "${REQUIREMENTS_FILE}"
    else
        log "no Python requirements declared; skipping pip"
    fi

    printf '%s\n' "${current_digest}" >"${REQUIREMENTS_STAMP_FILE}"
}

set_venv_permissions() {
    chown -R "${SENSOS_ADMIN_USER}:${SENSOS_DATA_GROUP}" "${VENV_DIR}"
    find "${VENV_DIR}" -type d -exec chmod 0755 '{}' +
    find "${VENV_DIR}" -type f -exec chmod 0644 '{}' +
    find "${VENV_DIR}/bin" -type f -exec chmod 0755 '{}' +
}

main() {
    require_root
    require_inputs
    run_preflight
    require_identity
    require_python
    ensure_python_layout
    ensure_system_venv_support
    ensure_venv
    ensure_venv_pip
    ensure_python_build_support
    install_requirements_if_needed
    set_venv_permissions
}

main "$@"
