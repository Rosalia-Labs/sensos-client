#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CLIENT_ROOT="${SENSOS_REPO_ROOT:-${REPO_ROOT}}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
PRECHECK_SCRIPT="${CLIENT_ROOT}/setup/00-preflight"
BIRDNET_SETUP_HELPER="${DEPLOY_ROOT}/libexec/setup-birdnet.sh"

log() {
    printf '[setup/08-birdnet] %s\n' "$*"
}

die() {
    printf '[setup/08-birdnet] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

require_inputs() {
    [[ -x "${PRECHECK_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PRECHECK_SCRIPT}"
    [[ -x "${BIRDNET_SETUP_HELPER}" ]] || die "missing or non-executable BirdNET helper: ${BIRDNET_SETUP_HELPER}"
}

run_preflight() {
    [[ "${SENSOS_PREFLIGHT_QUIET:-0}" == "1" ]] || log "running preflight"
    "${PRECHECK_SCRIPT}"
}

main() {
    require_root
    require_inputs
    run_preflight
    "${BIRDNET_SETUP_HELPER}"
}

main "$@"
