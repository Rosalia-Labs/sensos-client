#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"
REINSTALL="${SENSOS_REINSTALL:-0}"
INSTALL_STATE_FILE="${DEPLOY_ROOT}/etc/install-state.env"
SYSTEM_CONFIG_STATE_FILE="${DEPLOY_ROOT}/etc/system-config-state.env"
MAIN_VENV_DIR="${DEPLOY_ROOT}/python/venv"
BIRDNET_VENV_DIR="${DEPLOY_ROOT}/python/birdnet-venv"

log() {
    printf '[setup/install] %s\n' "$*"
}

die() {
    printf '[setup/install] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

purge_retry_artifacts() {
    [[ "${REINSTALL}" == "1" ]] || return 0

    log "reinstall mode enabled; clearing transient install artifacts"

    if [[ -d "${MAIN_VENV_DIR}" ]]; then
        rm -rf "${MAIN_VENV_DIR}"
        log "removed ${MAIN_VENV_DIR}"
    fi

    if [[ -d "${BIRDNET_VENV_DIR}" ]]; then
        rm -rf "${BIRDNET_VENV_DIR}"
        log "removed ${BIRDNET_VENV_DIR}"
    fi

    if [[ -f "${INSTALL_STATE_FILE}" ]]; then
        rm -f "${INSTALL_STATE_FILE}"
        log "removed ${INSTALL_STATE_FILE}"
    fi

    if [[ -f "${SYSTEM_CONFIG_STATE_FILE}" ]]; then
        rm -f "${SYSTEM_CONFIG_STATE_FILE}"
        log "removed ${SYSTEM_CONFIG_STATE_FILE}"
    fi
}

run_step() {
    local step_path="$1"

    [[ -x "${step_path}" ]] || die "missing or non-executable setup step: ${step_path}"
    log "running $(basename "${step_path}")"
    "${step_path}"
}

main() {
    local step_path

    require_root
    export SENSOS_PREFLIGHT_QUIET=1
    purge_retry_artifacts

    while IFS= read -r step_path; do
        run_step "${step_path}"
    done < <(find "${SCRIPT_DIR}" -maxdepth 1 -type f -name '[0-9][0-9]-*' | sort)

    log "setup complete"
}

main "$@"
