#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"

PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
MIGRATIONS_SCRIPT="${REPO_ROOT}/migrations/run"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"

log() {
    printf '[upgrade] %s\n' "$*"
}

die() {
    printf '[upgrade] ERROR: %s\n' "$*" >&2
    exit 1
}

validate_version_text() {
    local version="$1"
    [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || \
        die "invalid version '${version}'"
}

read_repo_version() {
    local version_file="${REPO_ROOT}/VERSION"
    local version

    [[ -f "${version_file}" ]] || die "missing VERSION file at ${version_file}"
    version="$(head -n 1 "${version_file}" | tr -d '[:space:]')"
    [[ -n "${version}" ]] || die "VERSION file is empty"
    validate_version_text "${version}"

    printf '%s\n' "${version}"
}

version_lt() {
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n 1)" == "$1" ]]
}

ensure_not_root() {
    [[ "${EUID}" -ne 0 ]] || die "run ${SCRIPT_PATH} as the repo owner; it will use sudo for privileged steps"
}

ensure_git_repo() {
    git -C "${REPO_ROOT}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || \
        die "not a git work tree: ${REPO_ROOT}"
}

ensure_clean_repo() {
    local status_output

    status_output="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all)"
    if [[ -n "${status_output}" ]]; then
        printf '%s\n' "${status_output}" >&2
        die "repo is not clean. Fix it with either 'git add -A && git commit -m \"...\"' or 'git stash push --include-untracked -m pre-upgrade', then rerun ${SCRIPT_PATH}"
    fi
}

ensure_upstream() {
    git -C "${REPO_ROOT}" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 || \
        die "current branch has no upstream; set one before running ${SCRIPT_PATH}"
}

sudo_run() {
    sudo env "SENSOS_REPO_ROOT=${REPO_ROOT}" "SENSOS_DEPLOY_ROOT=${DEPLOY_ROOT}" "$@"
}

main() {
    local old_version
    local pre_pull_version
    local new_version

    ensure_not_root
    ensure_git_repo
    ensure_clean_repo
    ensure_upstream

    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"
    [[ -x "${MIGRATIONS_SCRIPT}" ]] || die "missing or non-executable migrations script: ${MIGRATIONS_SCRIPT}"
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"

    log "verifying existing deployed client state before pulling"
    env "SENSOS_REPO_ROOT=${REPO_ROOT}" "SENSOS_DEPLOY_ROOT=${DEPLOY_ROOT}" "${PREFLIGHT_SCRIPT}" >/dev/null

    pre_pull_version="$(read_repo_version)"
    old_version="$(sudo_run awk -F= '/^INSTALLED_VERSION=/{print $2}' "${DEPLOY_ROOT}/etc/install-state.env" 2>/dev/null || true)"
    if [[ -z "${old_version}" ]]; then
        old_version="${pre_pull_version}"
    fi

    log "pulling the latest changes"
    git -C "${REPO_ROOT}" pull --ff-only

    new_version="$(read_repo_version)"
    if version_lt "${new_version}" "${old_version}"; then
        die "pulled revision moved repo version backward: ${old_version} -> ${new_version}"
    fi

    log "running migrations for ${old_version} -> ${new_version}"
    sudo_run "${MIGRATIONS_SCRIPT}" "${old_version}" "${new_version}"

    log "running setup"
    sudo_run "${SETUP_SCRIPT}"

    log "upgrade complete at version ${new_version}"
}

main "$@"
