#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
DEPLOY_ROOT="${SENSOS_DEPLOY_ROOT:-/sensos}"

PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
MIGRATIONS_SCRIPT="${REPO_ROOT}/migrations/run"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"
FORCE_PACKAGE_UPDATES=0
OFFLINE=0
INSTALL_STATE_FILE="${DEPLOY_ROOT}/etc/install-state.env"

log() {
    printf '[upgrade] %s\n' "$*"
}

die() {
    printf '[upgrade] ERROR: %s\n' "$*" >&2
    exit 1
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Pull the latest repo changes, run migrations, and reconcile the deployed client.

Defaults:
  APT refresh is lazy.
  Python requirements refresh is lazy.

Options:
  --force-package-updates
                     Force APT metadata refresh and Python dependency reinstall
  --offline          Skip git pull and use the repo contents already on disk
  --help             Show this help and exit
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force-package-updates)
                FORCE_PACKAGE_UPDATES=1
                ;;
            --offline)
                OFFLINE=1
                ;;
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

validate_version_text() {
    local version="$1"
    [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || \
        die "invalid version '${version}'"
}

read_repo_version() {
    local version_file="${REPO_ROOT}/VERSION"
    local version

    [[ -f "${version_file}" ]] || die "missing VERSION file at ${version_file}"
    version="$(head -n 1 "${version_file}" | tr -d '[:space:]')"
    [[ -n "${version}" ]] || die "VERSION file is empty"
    validate_version_text "${version}"

    printf '%s\n' "${version}"
}

version_lt() {
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n 1)" == "$1" ]]
}

ensure_not_root() {
    [[ "${EUID}" -ne 0 ]] || die "run ${SCRIPT_PATH} as the repo owner; it will use sudo for privileged steps"
}

ensure_git_repo() {
    git -C "${REPO_ROOT}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || \
        die "not a git work tree: ${REPO_ROOT}"
}

ensure_clean_repo() {
    local status_output

    status_output="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all)"
    if [[ -n "${status_output}" ]]; then
        printf '%s\n' "${status_output}" >&2
        die "repo is not clean. Fix it with either 'git add -A && git commit -m \"...\"' or 'git stash push --include-untracked -m pre-upgrade', then rerun ${SCRIPT_PATH}"
    fi
}

ensure_upstream() {
    git -C "${REPO_ROOT}" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 || \
        die "current branch has no upstream; set one before running ${SCRIPT_PATH}"
}

sudo_run() {
    local -a env_args=(
        "SENSOS_REPO_ROOT=${REPO_ROOT}"
        "SENSOS_DEPLOY_ROOT=${DEPLOY_ROOT}"
        "SENSOS_PREFLIGHT_QUIET=1"
    )

    if [[ "${FORCE_PACKAGE_UPDATES}" == "1" ]]; then
        env_args+=("SENSOS_EAGER_APT=1")
        env_args+=("SENSOS_EAGER_PIP=1")
    fi

    sudo env "${env_args[@]}" "$@"
}

have_deployed_client() {
    [[ -d "${DEPLOY_ROOT}/etc" ]] || return 1
    [[ -d "${DEPLOY_ROOT}/libexec" ]] || return 1
    return 0
}

verify_install_state() {
    sudo test -f "${INSTALL_STATE_FILE}" || \
        die "setup completed without writing ${INSTALL_STATE_FILE}"
}

read_install_flag() {
    local flag_name="$1"

    sudo_run awk -F= -v key="${flag_name}" '$1 == key { print $2 }' "${INSTALL_STATE_FILE}" 2>/dev/null || true
}

main() {
    local old_version
    local source_version
    local new_version

    parse_args "$@"
    ensure_not_root
    if [[ "${OFFLINE}" != "1" ]]; then
        ensure_git_repo
        ensure_clean_repo
        ensure_upstream
    fi

    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"
    [[ -x "${MIGRATIONS_SCRIPT}" ]] || die "missing or non-executable migrations script: ${MIGRATIONS_SCRIPT}"
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"

    log "verifying existing deployed client state before pulling"
    if [[ -f "${INSTALL_STATE_FILE}" ]]; then
        env "SENSOS_REPO_ROOT=${REPO_ROOT}" "SENSOS_DEPLOY_ROOT=${DEPLOY_ROOT}" "${PREFLIGHT_SCRIPT}" >/dev/null
    elif have_deployed_client; then
        log "install-state missing at ${INSTALL_STATE_FILE}; continuing and expecting setup to repair it"
    else
        die "no deployed client install-state found at ${INSTALL_STATE_FILE}; use ./install for first-time deployment. If a previous install failed and you only need newer repo contents, run 'git pull' manually and retry ./install instead of using ./upgrade"
    fi

    source_version="$(read_repo_version)"
    old_version="$(sudo_run awk -F= '/^INSTALLED_VERSION=/{print $2}' "${INSTALL_STATE_FILE}" 2>/dev/null || true)"
    if [[ -z "${old_version}" ]]; then
        old_version="${source_version}"
    fi

    if [[ "${OFFLINE}" == "1" ]]; then
        log "offline mode enabled; skipping git pull and using repo contents already on disk"
    else
        log "pulling the latest changes"
        git -C "${REPO_ROOT}" pull --ff-only
    fi

    new_version="$(read_repo_version)"
    if [[ "${OFFLINE}" != "1" ]] && version_lt "${new_version}" "${old_version}"; then
        die "pulled revision moved repo version backward: ${old_version} -> ${new_version}"
    fi

    log "running migrations for ${old_version} -> ${new_version}"
    sudo_run "${MIGRATIONS_SCRIPT}" "${old_version}" "${new_version}"

    log "running setup"
    sudo_run "${SETUP_SCRIPT}"
    verify_install_state

    log "upgrade complete at version ${new_version}"
    if [[ "$(read_install_flag REBOOT_REQUIRED)" == "1" ]]; then
        log "REBOOT REQUIRED: Raspberry Pi hardware changes were applied but are not fully active yet"
    fi
}

main "$@"
